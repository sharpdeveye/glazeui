@* GzSeparator — Subtle divider for grouping content *@

<div
    @attributes="GetFilteredAttributes()"
    role="@(Decorative ? "none" : "separator")"
    aria-orientation="@(Decorative ? null : OrientationValue)"
    class="@ComputedClass">
</div>

@code {
    /// <summary>Separator direction.</summary>
    [Parameter] public SeparatorOrientation Orientation { get; set; } = SeparatorOrientation.Horizontal;

    /// <summary>When true, renders as role="none" (decorative). Defaults to true.</summary>
    [Parameter] public bool Decorative { get; set; } = true;

    /// <summary>Additional HTML attributes passed through to the div element.</summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string OrientationValue => Orientation == SeparatorOrientation.Horizontal
        ? "horizontal"
        : "vertical";

    private string ComputedClass => Tw.Merge(
        "shrink-0 bg-border/50",
        Orientation == SeparatorOrientation.Horizontal ? "h-px w-full" : "h-full w-px",
        GetUserClass()
    );

    private string? GetUserClass() =>
        AdditionalAttributes?.TryGetValue("class", out var cls) == true
            ? cls?.ToString() : null;

    private Dictionary<string, object> GetFilteredAttributes()
    {
        if (AdditionalAttributes is null) return new();
        return AdditionalAttributes
            .Where(kvp => !kvp.Key.Equals("class", StringComparison.OrdinalIgnoreCase))
            .ToDictionary(kvp => kvp.Key, kvp => kvp.Value);
    }
}
