@* GzButton — Premium interactive button with loading, icon, and 6 variants *@

<button
    type="@Type"
    @attributes="GetFilteredAttributes()"
    class="@ComputedClass"
    disabled="@(Disabled || Loading)"
    aria-busy="@(Loading ? "true" : null)"
    @onclick="OnClick">

    @if (Loading)
    {
        <svg class="me-2 size-4 animate-spin text-current opacity-70" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
    }
    else if (Icon is not null)
    {
        <span class="me-2 size-4">@Icon</span>
    }

    @ChildContent
</button>

@code {
    /// <summary>Button content (text, icons, or mixed).</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>Optional leading icon slot.</summary>
    [Parameter] public RenderFragment? Icon { get; set; }

    /// <summary>Visual style variant.</summary>
    [Parameter] public ComponentVariant Variant { get; set; } = ComponentVariant.Default;

    /// <summary>Size preset.</summary>
    [Parameter] public ComponentSize Size { get; set; } = ComponentSize.Md;

    /// <summary>HTML button type attribute.</summary>
    [Parameter] public string Type { get; set; } = "button";

    /// <summary>Whether the button is disabled.</summary>
    [Parameter] public bool Disabled { get; set; }

    /// <summary>Whether the button shows a loading spinner.</summary>
    [Parameter] public bool Loading { get; set; }

    /// <summary>Click event callback.</summary>
    [Parameter] public EventCallback<MouseEventArgs> OnClick { get; set; }

    /// <summary>Additional HTML attributes passed through to the button element.</summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    // ─── Base premium classes ───────────────────────────
    private const string BaseClasses =
        "inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md " +
        "text-sm font-medium cursor-pointer " +
        "ring-offset-background transition-all duration-200 ease-out " +
        "focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 " +
        "active:scale-[0.98] " +
        "disabled:pointer-events-none disabled:opacity-50 " +
        "[&_svg]:pointer-events-none [&_svg]:shrink-0";

    private string ComputedClass => Tw.Merge(
        BaseClasses,
        GetVariantClass(),
        GetSizeClass(),
        GetUserClass()
    );

    private string GetVariantClass() => Variant switch
    {
        ComponentVariant.Default     => "bg-primary text-primary-foreground shadow-sm inset-shadow-sm inset-shadow-white/20 hover:bg-primary/90",
        ComponentVariant.Destructive => "bg-destructive text-destructive-foreground shadow-sm inset-shadow-sm inset-shadow-white/20 hover:bg-destructive/90",
        ComponentVariant.Outline     => "border border-border/50 bg-background shadow-sm hover:bg-accent hover:text-accent-foreground",
        ComponentVariant.Secondary   => "bg-secondary text-secondary-foreground shadow-sm hover:bg-secondary/80",
        ComponentVariant.Ghost       => "hover:bg-accent hover:text-accent-foreground",
        ComponentVariant.Link        => "text-primary underline-offset-4 hover:underline",
        _ => ""
    };

    private string GetSizeClass() => Size switch
    {
        ComponentSize.Sm   => "h-8 rounded-md px-3 text-xs",
        ComponentSize.Md   => "h-9 px-4 py-2",
        ComponentSize.Lg   => "h-10 rounded-md px-8",
        ComponentSize.Icon => "size-9",
        _ => ""
    };

    private string? GetUserClass() =>
        AdditionalAttributes?.TryGetValue("class", out var cls) == true
            ? cls?.ToString() : null;

    private Dictionary<string, object> GetFilteredAttributes()
    {
        if (AdditionalAttributes is null) return new();
        return AdditionalAttributes
            .Where(kvp => !kvp.Key.Equals("class", StringComparison.OrdinalIgnoreCase))
            .ToDictionary(kvp => kvp.Key, kvp => kvp.Value);
    }
}
