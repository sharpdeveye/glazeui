@* GzContextMenu — Right-click context menu with items *@

<div @attributes="GetFilteredAttributes()"
     class="@ComputedClass"
     @oncontextmenu="HandleContextMenu"
     @oncontextmenu:preventDefault="true">
    @Trigger

    @if (_isOpen)
    {
        <div class="fixed inset-0 z-40" @onclick="Close" @oncontextmenu="Close" @oncontextmenu:preventDefault="true"></div>
        <div role="menu"
             class="@MenuClass"
             style="position: fixed; left: @(_x)px; top: @(_y)px;">
            @ChildContent
        </div>
    }
</div>

@code {
    /// <summary>The element that triggers the context menu.</summary>
    [Parameter] public RenderFragment? Trigger { get; set; }

    /// <summary>Menu items — use GzDropdownMenuItem inside.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>Additional HTML attributes.</summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private bool _isOpen;
    private double _x;
    private double _y;

    private string ComputedClass => Tw.Merge(
        "relative",
        GetUserClass()
    );

    private const string MenuClass =
        "z-50 min-w-[8rem] overflow-hidden rounded-md " +
        "border border-border/50 bg-popover p-1 text-popover-foreground shadow-lg " +
        "animate-in fade-in-0 zoom-in-95 duration-150";

    private void HandleContextMenu(MouseEventArgs e)
    {
        _x = e.ClientX;
        _y = e.ClientY;
        _isOpen = true;
    }

    private void Close() => _isOpen = false;

    private string? GetUserClass() =>
        AdditionalAttributes?.TryGetValue("class", out var cls) == true
            ? cls?.ToString() : null;

    private Dictionary<string, object> GetFilteredAttributes()
    {
        if (AdditionalAttributes is null) return new();
        return AdditionalAttributes
            .Where(kvp => !kvp.Key.Equals("class", StringComparison.OrdinalIgnoreCase))
            .ToDictionary(kvp => kvp.Key, kvp => kvp.Value);
    }
}
