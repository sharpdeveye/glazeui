@* GzSelect — Dropdown select with keyboard navigation and ARIA combobox pattern *@

<div @attributes="GetFilteredAttributes()"
     class="@ComputedClass">
    @* Trigger *@
    <button type="button"
            role="combobox"
            aria-expanded="@_isOpen.ToString().ToLower()"
            aria-haspopup="listbox"
            aria-activedescendant="@(_isOpen && _highlightIndex >= 0 ? $"gz-select-opt-{_highlightIndex}" : null)"
            aria-label="@(string.IsNullOrWhiteSpace(Placeholder) ? "Select an option" : Placeholder)"
            class="@TriggerClass"
            disabled="@Disabled"
            @onclick="Toggle"
            @onkeydown="HandleKeyDown">
        <span class="@(string.IsNullOrWhiteSpace(SelectedLabel) ? "text-muted-foreground" : "")">
            @(string.IsNullOrWhiteSpace(SelectedLabel) ? Placeholder : SelectedLabel)
        </span>
        <svg class="@ChevronClass" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
        </svg>
    </button>

    @* Dropdown *@
    @if (_isOpen)
    {
        <div class="fixed inset-0 z-40" @onclick="Close"></div>
        <div role="listbox"
             class="@DropdownClass">
            @for (var i = 0; i < _enabledOptions.Count; i++)
            {
                var option = _enabledOptions[i];
                var index = i;
                var isSelected = option.Value == Value;
                var isHighlighted = index == _highlightIndex;
                <div role="option"
                     id="@($"gz-select-opt-{index}")"
                     aria-selected="@isSelected.ToString().ToLower()"
                     class="@GetOptionClass(isSelected, isHighlighted)"
                     @onclick="() => SelectOption(option)"
                     @onclick:stopPropagation="true"
                     @onmouseenter="() => _highlightIndex = index">
                    <span>@option.Label</span>
                    @if (isSelected)
                    {
                        <svg class="size-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                        </svg>
                    }
                </div>
            }
            @foreach (var option in Options.Where(o => o.Disabled))
            {
                <div role="option"
                     aria-disabled="true"
                     class="@GetOptionClass(false, false) pointer-events-none opacity-50">
                    <span>@option.Label</span>
                </div>
            }
        </div>
    }
</div>

@code {
    /// <summary>List of selectable options.</summary>
    [Parameter] public List<SelectOption> Options { get; set; } = new();

    /// <summary>Currently selected value — supports two-way binding.</summary>
    [Parameter] public string? Value { get; set; }

    /// <summary>Callback when selection changes.</summary>
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }

    /// <summary>Placeholder text shown when no option is selected.</summary>
    [Parameter] public string Placeholder { get; set; } = "Select an option";

    /// <summary>Whether the select is disabled.</summary>
    [Parameter] public bool Disabled { get; set; }

    /// <summary>Additional HTML attributes.</summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private bool _isOpen;
    private int _highlightIndex;
    private List<SelectOption> _enabledOptions = new();
    private string? SelectedLabel => Options.FirstOrDefault(o => o.Value == Value)?.Label;

    protected override void OnParametersSet()
    {
        _enabledOptions = Options.Where(o => !o.Disabled).ToList();
    }

    private string ComputedClass => Tw.Merge(
        "relative w-full",
        GetUserClass()
    );

    private const string TriggerClass =
        "flex h-10 w-full items-center justify-between rounded-md px-3 py-2 text-sm cursor-pointer " +
        "bg-background inset-ring inset-ring-border/50 " +
        "transition-all duration-200 ease-out " +
        "hover:bg-accent/50 " +
        "focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 ring-offset-background " +
        "disabled:pointer-events-none disabled:opacity-50";

    private string ChevronClass => Tw.Merge(
        "size-4 shrink-0 text-muted-foreground transition-transform duration-200",
        _isOpen ? "rotate-180" : ""
    );

    private const string DropdownClass =
        "absolute z-50 mt-1 w-full overflow-hidden rounded-md border border-border/50 bg-popover p-1 " +
        "text-popover-foreground shadow-lg max-h-60 overflow-y-auto";

    private string GetOptionClass(bool isSelected, bool isHighlighted) => Tw.Merge(
        "relative flex w-full items-center justify-between rounded-sm px-2 py-1.5 text-sm cursor-pointer",
        "transition-colors duration-100 ease-out",
        isHighlighted ? "bg-accent text-accent-foreground" : "hover:bg-accent/50",
        isSelected ? "font-medium" : ""
    );

    private void Toggle()
    {
        if (Disabled) return;
        _isOpen = !_isOpen;
        if (_isOpen) InitHighlight();
    }

    private void InitHighlight()
    {
        var selectedIndex = _enabledOptions.FindIndex(o => o.Value == Value);
        _highlightIndex = selectedIndex >= 0 ? selectedIndex : 0;
    }

    private async Task SelectOption(SelectOption option)
    {
        if (option.Disabled) return;
        Value = option.Value;
        _isOpen = false;
        await ValueChanged.InvokeAsync(Value);
    }

    private void Close() => _isOpen = false;

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        switch (e.Key)
        {
            case "Escape":
                _isOpen = false;
                break;
            case "Enter" or " ":
                if (_isOpen && _highlightIndex >= 0 && _highlightIndex < _enabledOptions.Count)
                {
                    _ = SelectOption(_enabledOptions[_highlightIndex]);
                }
                else
                {
                    _isOpen = true;
                    InitHighlight();
                }
                break;
            case "ArrowDown":
                if (!_isOpen)
                {
                    _isOpen = true;
                    InitHighlight();
                }
                else
                {
                    _highlightIndex = Math.Min(_enabledOptions.Count - 1, _highlightIndex + 1);
                }
                break;
            case "ArrowUp":
                if (_isOpen)
                    _highlightIndex = Math.Max(0, _highlightIndex - 1);
                break;
            case "Home":
                if (_isOpen) _highlightIndex = 0;
                break;
            case "End":
                if (_isOpen) _highlightIndex = _enabledOptions.Count - 1;
                break;
        }
    }

    private string? GetUserClass() =>
        AdditionalAttributes?.TryGetValue("class", out var cls) == true
            ? cls?.ToString() : null;

    private Dictionary<string, object> GetFilteredAttributes()
    {
        if (AdditionalAttributes is null) return new();
        return AdditionalAttributes
            .Where(kvp => !kvp.Key.Equals("class", StringComparison.OrdinalIgnoreCase))
            .ToDictionary(kvp => kvp.Key, kvp => kvp.Value);
    }
}
