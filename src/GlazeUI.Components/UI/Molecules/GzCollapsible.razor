@* GzCollapsible — Expandable content section with trigger *@

<div @attributes="GetFilteredAttributes()"
     class="@ComputedClass">
    <div @onclick="Toggle" @onclick:stopPropagation="true">
        @Trigger
    </div>

    @if (_isOpen)
    {
        <div class="overflow-hidden animate-in fade-in-0 slide-in-from-top-2 duration-200">
            @ChildContent
        </div>
    }
</div>

@code {
    /// <summary>Trigger element that toggles the collapsible.</summary>
    [Parameter] public RenderFragment? Trigger { get; set; }

    /// <summary>Collapsible content.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>Whether the collapsible is open — supports two-way binding.</summary>
    [Parameter] public bool Open { get; set; }

    /// <summary>Two-way binding callback.</summary>
    [Parameter] public EventCallback<bool> OpenChanged { get; set; }

    /// <summary>Additional HTML attributes.</summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private bool _isOpen;

    protected override void OnParametersSet() => _isOpen = Open;

    private string ComputedClass => Tw.Merge(
        "space-y-2",
        GetUserClass()
    );

    private async Task Toggle()
    {
        _isOpen = !_isOpen;
        Open = _isOpen;
        await OpenChanged.InvokeAsync(_isOpen);
    }

    private string? GetUserClass() =>
        AdditionalAttributes?.TryGetValue("class", out var cls) == true
            ? cls?.ToString() : null;

    private Dictionary<string, object> GetFilteredAttributes()
    {
        if (AdditionalAttributes is null) return new();
        return AdditionalAttributes
            .Where(kvp => !kvp.Key.Equals("class", StringComparison.OrdinalIgnoreCase))
            .ToDictionary(kvp => kvp.Key, kvp => kvp.Value);
    }
}
