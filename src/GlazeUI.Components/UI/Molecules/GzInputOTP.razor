@* GzInputOTP — One-time password input with segmented boxes *@

<div @attributes="GetFilteredAttributes()"
     class="@ComputedClass"
     role="group"
     aria-label="One-time password">
    @for (var i = 0; i < Length; i++)
    {
        var index = i;
        var hasValue = index < _values.Length && _values[index] != '\0';
        <input type="text"
               inputmode="numeric"
               maxlength="1"
               autocomplete="one-time-code"
               class="@GetCellClass(hasValue)"
               value="@(hasValue ? _values[index].ToString() : "")"
               @oninput="e => HandleInput(e, index)"
               @onkeydown="e => HandleKeyDown(e, index)"
               @onfocus="e => HandleFocus(index)" />
        @if (i == Length / 2 - 1 && ShowSeparator)
        {
            <span class="text-muted-foreground/40 text-lg mx-1">-</span>
        }
    }
</div>

@code {
    /// <summary>Number of OTP digits.</summary>
    [Parameter] public int Length { get; set; } = 6;

    /// <summary>Whether to show separator in the middle.</summary>
    [Parameter] public bool ShowSeparator { get; set; } = true;

    /// <summary>Current OTP value — supports two-way binding.</summary>
    [Parameter] public string? Value { get; set; }

    /// <summary>Two-way binding callback.</summary>
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }

    /// <summary>Callback when all digits are entered.</summary>
    [Parameter] public EventCallback<string> OnComplete { get; set; }

    /// <summary>Whether the input is disabled.</summary>
    [Parameter] public bool Disabled { get; set; }

    /// <summary>Additional HTML attributes.</summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private char[] _values = Array.Empty<char>();
    private int _focusIndex;

    protected override void OnParametersSet()
    {
        if (_values.Length != Length)
            _values = new char[Length];

        if (!string.IsNullOrEmpty(Value))
        {
            for (var i = 0; i < Length && i < Value.Length; i++)
                _values[i] = Value[i];
        }
    }

    private string ComputedClass => Tw.Merge(
        "flex items-center gap-2",
        Disabled ? "opacity-50 pointer-events-none" : null,
        GetUserClass()
    );

    private string GetCellClass(bool hasValue) => Tw.Merge(
        "flex items-center justify-center size-10 rounded-md text-center text-sm font-medium",
        "inset-ring inset-ring-border/50 bg-transparent",
        "transition-all duration-200 ease-out",
        "focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 ring-offset-background",
        "selection:bg-primary selection:text-primary-foreground",
        hasValue ? "text-foreground" : "text-muted-foreground"
    );

    private async Task HandleInput(ChangeEventArgs e, int index)
    {
        var val = e.Value?.ToString() ?? "";
        if (val.Length > 0 && char.IsDigit(val[0]))
        {
            _values[index] = val[0];
            var combined = new string(_values).Replace("\0", "");
            Value = combined;
            await ValueChanged.InvokeAsync(combined);

            if (combined.Length == Length && OnComplete.HasDelegate)
                await OnComplete.InvokeAsync(combined);
        }
        else
        {
            _values[index] = '\0';
        }
    }

    private void HandleKeyDown(KeyboardEventArgs e, int index)
    {
        if (e.Key == "Backspace")
        {
            _values[index] = '\0';
        }
    }

    private void HandleFocus(int index)
    {
        _focusIndex = index;
    }

    private string? GetUserClass() =>
        AdditionalAttributes?.TryGetValue("class", out var cls) == true
            ? cls?.ToString() : null;

    private Dictionary<string, object> GetFilteredAttributes()
    {
        if (AdditionalAttributes is null) return new();
        return AdditionalAttributes
            .Where(kvp => !kvp.Key.Equals("class", StringComparison.OrdinalIgnoreCase))
            .ToDictionary(kvp => kvp.Key, kvp => kvp.Value);
    }
}
