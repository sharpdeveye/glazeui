@* GzFileUpload — File upload zone with file list, type/size validation *@

<div @attributes="GetFilteredAttributes()" class="@ComputedClass">
    @* ─── Upload Zone ────────────────────── *@
    <label class="@DropZoneClass">
        <InputFile OnChange="HandleFileSelected"
                   accept="@Accept"
                   multiple="@Multiple"
                   disabled="@Disabled"
                   class="sr-only" />

        <div class="flex flex-col items-center gap-3 py-6">
            <div class="@IconWrapperClass">
                <svg class="size-6 text-muted-foreground" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5" />
                </svg>
            </div>
            <div class="text-center">
                <p class="text-sm font-medium text-foreground">
                    <span>Click to upload or drag &amp; drop</span>
                </p>
                <p class="mt-1 text-xs text-muted-foreground">@HintText</p>
            </div>
        </div>
    </label>

    @* ─── File List ──────────────────────── *@
    @if (_files.Count > 0)
    {
        <div class="mt-3 space-y-2">
            @foreach (var file in _files)
            {
                <div class="flex items-center gap-3 rounded-md border border-border/30 bg-muted/20 px-3 py-2">
                    <svg class="size-4 shrink-0 text-muted-foreground" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                    </svg>
                    <div class="flex-1 min-w-0">
                        <p class="truncate text-sm font-medium text-foreground">@file.Name</p>
                        <p class="text-xs text-muted-foreground">@FormatSize(file.Size)</p>
                    </div>
                    @if (file.Error is not null)
                    {
                        <span class="text-xs text-destructive">@file.Error</span>
                    }
                    <button type="button"
                            class="shrink-0 rounded-md p-1 text-muted-foreground transition-colors duration-150 hover:bg-destructive/10 hover:text-destructive cursor-pointer"
                            @onclick="() => RemoveFile(file)">
                        <svg class="size-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                    </button>
                </div>
            }
        </div>
    }
</div>

@code {
    /// <summary>Accepted file types (HTML accept attribute), e.g. ".pdf,.png,image/*".</summary>
    [Parameter] public string? Accept { get; set; }

    /// <summary>Maximum file size in bytes. 0 = no limit.</summary>
    [Parameter] public long MaxSizeBytes { get; set; }

    /// <summary>Whether multiple files can be selected.</summary>
    [Parameter] public bool Multiple { get; set; }

    /// <summary>Whether the upload zone is disabled.</summary>
    [Parameter] public bool Disabled { get; set; }

    /// <summary>Callback when files are added. Receives the list of valid IBrowserFile instances.</summary>
    [Parameter] public EventCallback<List<IBrowserFile>> OnFilesChanged { get; set; }

    /// <summary>Additional HTML attributes.</summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private List<UploadedFile> _files = new();

    private string HintText
    {
        get
        {
            var parts = new List<string>();
            if (!string.IsNullOrEmpty(Accept)) parts.Add(Accept);
            if (MaxSizeBytes > 0) parts.Add($"Max {FormatSize(MaxSizeBytes)}");
            return string.Join(" • ", parts);
        }
    }

    private class UploadedFile
    {
        public string Name { get; set; } = "";
        public long Size { get; set; }
        public string? Error { get; set; }
        public IBrowserFile? BrowserFile { get; set; }
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        var files = Multiple ? e.GetMultipleFiles(20).ToList() : new List<IBrowserFile> { e.File };
        foreach (var file in files)
        {
            var uploadFile = new UploadedFile
            {
                Name = file.Name,
                Size = file.Size,
                BrowserFile = file
            };

            if (MaxSizeBytes > 0 && file.Size > MaxSizeBytes)
            {
                uploadFile.Error = $"Exceeds {FormatSize(MaxSizeBytes)} limit";
            }

            if (Multiple)
                _files.Add(uploadFile);
            else
                _files = new List<UploadedFile> { uploadFile };
        }

        await NotifyFiles();
    }

    private async Task RemoveFile(UploadedFile file)
    {
        _files.Remove(file);
        await NotifyFiles();
    }

    private async Task NotifyFiles()
    {
        if (OnFilesChanged.HasDelegate)
        {
            var validFiles = _files
                .Where(f => f.Error is null && f.BrowserFile is not null)
                .Select(f => f.BrowserFile!)
                .ToList();
            await OnFilesChanged.InvokeAsync(validFiles);
        }
    }

    private static string FormatSize(long bytes)
    {
        if (bytes >= 1024L * 1024 * 1024) return $"{bytes / (1024.0 * 1024.0 * 1024.0):F1} GB";
        if (bytes >= 1024L * 1024) return $"{bytes / (1024.0 * 1024.0):F1} MB";
        if (bytes >= 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes} B";
    }

    // ─── Styling ────────────────────────────────────
    private string ComputedClass => Tw.Merge(GetUserClass());

    private string DropZoneClass => Tw.Merge(
        "flex cursor-pointer flex-col items-center rounded-lg border-2 border-dashed px-6 py-4 transition-all duration-200",
        "border-border/50 bg-muted/20 hover:border-primary/50 hover:bg-muted/40",
        Disabled ? "cursor-not-allowed opacity-50 pointer-events-none" : null
    );

    private string IconWrapperClass => "rounded-full bg-muted p-3";

    private string? GetUserClass() =>
        AdditionalAttributes?.TryGetValue("class", out var cls) == true
            ? cls?.ToString() : null;

    private Dictionary<string, object> GetFilteredAttributes()
    {
        if (AdditionalAttributes is null) return new();
        return AdditionalAttributes
            .Where(kvp => !kvp.Key.Equals("class", StringComparison.OrdinalIgnoreCase))
            .ToDictionary(kvp => kvp.Key, kvp => kvp.Value);
    }
}
