@* GzCommand — Command palette (searchable action list) *@

@if (Open)
{
    <div class="fixed inset-0 z-50" @onkeydown="HandleKeyDown">
        @* Backdrop *@
        <div class="fixed inset-0 bg-foreground/60 backdrop-blur-sm animate-in fade-in-0 duration-150"
             @onclick="Close"></div>

        @* Command panel *@
        <div class="fixed start-1/2 top-[20%] z-50 w-full max-w-lg -translate-x-1/2 animate-in fade-in-0 zoom-in-95 slide-in-from-top-2 duration-200">
            <div @attributes="GetFilteredAttributes()"
                 class="@ComputedClass">
                @* Search input *@
                <div class="flex items-center border-b border-border/50 px-3">
                    <svg class="me-2 size-4 shrink-0 text-muted-foreground" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
                    </svg>
                    <input type="text"
                           placeholder="@Placeholder"
                           class="flex h-11 w-full bg-transparent py-3 text-sm text-foreground placeholder:text-muted-foreground focus-visible:outline-none"
                           value="@_searchText"
                           @oninput="HandleSearch" />
                </div>

                @* Results *@
                <div class="max-h-72 overflow-y-auto p-1">
                    @if (_filteredGroups.Count == 0)
                    {
                        <p class="py-6 text-center text-sm text-muted-foreground">No results found.</p>
                    }
                    else
                    {
                        @foreach (var group in _filteredGroups)
                        {
                            <div class="px-2 py-1.5 text-xs font-medium text-muted-foreground">@group.Label</div>
                            @foreach (var item in group.Items)
                            {
                                var cmd = item;
                                <div role="option"
                                     class="@GetItemClass()"
                                     @onclick="() => SelectItem(cmd)">
                                    @if (cmd.Icon is not null)
                                    {
                                        <span class="me-2 shrink-0">@cmd.Icon</span>
                                    }
                                    <span class="flex-1">@cmd.Label</span>
                                    @if (!string.IsNullOrWhiteSpace(cmd.Shortcut))
                                    {
                                        <kbd class="ms-auto rounded border border-border/50 bg-muted px-1.5 py-0.5 text-[10px] font-mono text-muted-foreground">@cmd.Shortcut</kbd>
                                    }
                                </div>
                            }
                        }
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    /// <summary>Whether the command palette is open.</summary>
    [Parameter] public bool Open { get; set; }

    /// <summary>Two-way binding callback.</summary>
    [Parameter] public EventCallback<bool> OpenChanged { get; set; }

    /// <summary>Command groups.</summary>
    [Parameter] public List<CommandGroup> Groups { get; set; } = new();

    /// <summary>Search placeholder text.</summary>
    [Parameter] public string Placeholder { get; set; } = "Type a command or search...";

    /// <summary>Callback when a command is selected.</summary>
    [Parameter] public EventCallback<CommandItem> OnSelect { get; set; }

    /// <summary>Additional HTML attributes.</summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string _searchText = "";
    private List<CommandGroup> _filteredGroups = new();

    protected override void OnParametersSet()
    {
        if (Open && string.IsNullOrEmpty(_searchText))
            _filteredGroups = Groups;
    }

    private string ComputedClass => Tw.Merge(
        "overflow-hidden rounded-xl border border-border/50 bg-popover shadow-2xl",
        GetUserClass()
    );

    private string GetItemClass() => Tw.Merge(
        "relative flex items-center rounded-sm px-2 py-1.5 text-sm cursor-pointer",
        "transition-colors duration-100",
        "hover:bg-accent hover:text-accent-foreground"
    );

    private void HandleSearch(ChangeEventArgs e)
    {
        _searchText = e.Value?.ToString() ?? "";

        if (string.IsNullOrWhiteSpace(_searchText))
        {
            _filteredGroups = Groups;
            return;
        }

        _filteredGroups = Groups
            .Select(g => new CommandGroup
            {
                Label = g.Label,
                Items = g.Items
                    .Where(i => i.Label.Contains(_searchText, StringComparison.OrdinalIgnoreCase))
                    .ToList()
            })
            .Where(g => g.Items.Count > 0)
            .ToList();
    }

    private async Task SelectItem(CommandItem item)
    {
        await Close();
        if (OnSelect.HasDelegate)
            await OnSelect.InvokeAsync(item);
        if (item.OnSelect.HasDelegate)
            await item.OnSelect.InvokeAsync();
    }

    private async Task Close()
    {
        _searchText = "";
        Open = false;
        await OpenChanged.InvokeAsync(false);
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape") await Close();
    }

    private string? GetUserClass() =>
        AdditionalAttributes?.TryGetValue("class", out var cls) == true
            ? cls?.ToString() : null;

    private Dictionary<string, object> GetFilteredAttributes()
    {
        if (AdditionalAttributes is null) return new();
        return AdditionalAttributes
            .Where(kvp => !kvp.Key.Equals("class", StringComparison.OrdinalIgnoreCase))
            .ToDictionary(kvp => kvp.Key, kvp => kvp.Value);
    }
}
