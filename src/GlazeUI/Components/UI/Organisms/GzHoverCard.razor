@* GzHoverCard — Rich tooltip that appears on hover with delay *@

<div @attributes="GetFilteredAttributes()"
     class="@ComputedClass"
     @onmouseenter="Open"
     @onmouseleave="ScheduleClose">
    @* Trigger *@
    <div class="inline-block">
        @Trigger
    </div>

    @* Card *@
    @if (_isOpen)
    {
        <div class="@CardClass"
             @onmouseenter="CancelClose"
             @onmouseleave="ScheduleClose">
            @ChildContent
        </div>
    }
</div>

@code {
    /// <summary>The element that triggers the hover card.</summary>
    [Parameter] public RenderFragment? Trigger { get; set; }

    /// <summary>Hover card content.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>Delay in ms before showing.</summary>
    [Parameter] public int OpenDelay { get; set; } = 200;

    /// <summary>Delay in ms before hiding.</summary>
    [Parameter] public int CloseDelay { get; set; } = 300;

    /// <summary>Horizontal alignment.</summary>
    [Parameter] public string Align { get; set; } = "center";

    /// <summary>Additional HTML attributes.</summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private bool _isOpen;
    private System.Timers.Timer? _openTimer;
    private System.Timers.Timer? _closeTimer;

    private string ComputedClass => Tw.Merge(
        "relative inline-block",
        GetUserClass()
    );

    private string CardClass => Tw.Merge(
        "absolute z-50 mt-2 w-64 rounded-lg border border-border/50 bg-popover p-4",
        "text-popover-foreground shadow-lg",
        "animate-in fade-in-0 zoom-in-95 slide-in-from-top-2 duration-150",
        GetAlignClass()
    );

    private string GetAlignClass() => Align switch
    {
        "start" => "start-0",
        "end"   => "end-0",
        _       => "start-1/2 -translate-x-1/2"
    };

    private void Open()
    {
        _closeTimer?.Stop();
        _openTimer?.Dispose();
        _openTimer = new System.Timers.Timer(OpenDelay);
        _openTimer.Elapsed += (_, _) =>
        {
            _openTimer?.Dispose();
            InvokeAsync(() => { _isOpen = true; StateHasChanged(); });
        };
        _openTimer.AutoReset = false;
        _openTimer.Start();
    }

    private void ScheduleClose()
    {
        _openTimer?.Stop();
        _closeTimer?.Dispose();
        _closeTimer = new System.Timers.Timer(CloseDelay);
        _closeTimer.Elapsed += (_, _) =>
        {
            _closeTimer?.Dispose();
            InvokeAsync(() => { _isOpen = false; StateHasChanged(); });
        };
        _closeTimer.AutoReset = false;
        _closeTimer.Start();
    }

    private void CancelClose() => _closeTimer?.Stop();

    private string? GetUserClass() =>
        AdditionalAttributes?.TryGetValue("class", out var cls) == true
            ? cls?.ToString() : null;

    private Dictionary<string, object> GetFilteredAttributes()
    {
        if (AdditionalAttributes is null) return new();
        return AdditionalAttributes
            .Where(kvp => !kvp.Key.Equals("class", StringComparison.OrdinalIgnoreCase))
            .ToDictionary(kvp => kvp.Key, kvp => kvp.Value);
    }

    public void Dispose()
    {
        _openTimer?.Dispose();
        _closeTimer?.Dispose();
    }
}
