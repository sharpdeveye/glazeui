@* GzToast — Temporary notification with auto-dismiss and close button *@

@if (_visible)
{
    <div @attributes="GetFilteredAttributes()"
         class="@ComputedClass"
         role="alert"
         aria-live="assertive">
        <div class="flex items-start gap-3">
            @* Icon *@
            <div class="shrink-0 mt-0.5">
                @switch (Variant)
                {
                    case ToastVariant.Success:
                        <svg class="size-4 text-primary" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                        break;
                    case ToastVariant.Error:
                        <svg class="size-4 text-destructive" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" /></svg>
                        break;
                    default:
                        <svg class="size-4 text-foreground" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z" /></svg>
                        break;
                }
            </div>

            @* Content *@
            <div class="flex-1 min-w-0">
                @if (!string.IsNullOrWhiteSpace(Title))
                {
                    <p class="text-sm font-medium text-foreground">@Title</p>
                }
                @if (ChildContent is not null)
                {
                    <p class="mt-1 text-sm text-muted-foreground">@ChildContent</p>
                }
            </div>

            @* Close *@
            <button type="button"
                    class="shrink-0 rounded-sm p-0.5 text-muted-foreground/60 transition-colors duration-200 cursor-pointer hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring"
                    aria-label="Dismiss"
                    @onclick="Dismiss">
                <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
        </div>
    </div>
}

@code {
    /// <summary>Toast heading.</summary>
    [Parameter] public string? Title { get; set; }

    /// <summary>Toast body content.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>Visual variant: Default, Success, Error.</summary>
    [Parameter] public ToastVariant Variant { get; set; } = ToastVariant.Default;

    /// <summary>Auto-dismiss after this many milliseconds. 0 = never.</summary>
    [Parameter] public int Duration { get; set; } = 5000;

    /// <summary>Controls visibility — supports two-way binding.</summary>
    [Parameter] public bool Visible { get; set; } = true;

    /// <summary>Callback when visibility changes.</summary>
    [Parameter] public EventCallback<bool> VisibleChanged { get; set; }

    /// <summary>Additional HTML attributes.</summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private bool _visible;
    private System.Timers.Timer? _timer;

    protected override void OnParametersSet()
    {
        _visible = Visible;
        if (_visible && Duration > 0)
            StartTimer();
    }

    private void StartTimer()
    {
        _timer?.Dispose();
        _timer = new System.Timers.Timer(Duration);
        _timer.Elapsed += async (_, _) =>
        {
            _timer?.Dispose();
            await InvokeAsync(Dismiss);
        };
        _timer.AutoReset = false;
        _timer.Start();
    }

    private async Task Dismiss()
    {
        _visible = false;
        await VisibleChanged.InvokeAsync(false);
        StateHasChanged();
    }

    private string ComputedClass => Tw.Merge(
        "pointer-events-auto w-full max-w-sm overflow-hidden rounded-lg",
        "border border-border/50 bg-background shadow-lg",
        "p-4 transition-all duration-300 ease-out",
        GetUserClass()
    );

    private string? GetUserClass() =>
        AdditionalAttributes?.TryGetValue("class", out var cls) == true
            ? cls?.ToString() : null;

    private Dictionary<string, object> GetFilteredAttributes()
    {
        if (AdditionalAttributes is null) return new();
        return AdditionalAttributes
            .Where(kvp => !kvp.Key.Equals("class", StringComparison.OrdinalIgnoreCase))
            .ToDictionary(kvp => kvp.Key, kvp => kvp.Value);
    }

    public void Dispose() => _timer?.Dispose();
}
