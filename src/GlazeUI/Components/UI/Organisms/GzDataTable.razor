@* GzDataTable — Enterprise-grade data grid with sorting, filtering, pagination,
   column visibility, row selection, density toggle, CSV export, and loading state *@
@typeparam TItem

<div @attributes="GetFilteredAttributes()" class="@ComputedClass">
    @* ─── Toolbar ─────────────────────────── *@
    <div class="flex flex-wrap items-center gap-3 border-b border-border/30 p-3">
        @if (Filterable)
        {
            <div class="flex-1 min-w-48">
                <GzInput Placeholder="@FilterPlaceholder"
                         Value="@_filterText"
                         ValueChanged="HandleFilter">
                    <StartContent>
                        <svg fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" /></svg>
                    </StartContent>
                </GzInput>
            </div>
        }

        <div class="flex items-center gap-1.5 ms-auto">
            @if (!string.IsNullOrEmpty(_filterText))
            {
                <GzBadge Variant="ComponentVariant.Secondary">@_filteredItems.Count results</GzBadge>
            }

            @if (Selectable && _selectedKeys.Count > 0)
            {
                <GzBadge>@_selectedKeys.Count selected</GzBadge>
            }

            @* Density Toggle *@
            <GzButton Variant="ComponentVariant.Ghost" Size="ComponentSize.Icon"
                      aria-label="Toggle density"
                      OnClick="CycleDensity">
                <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5M3.75 17.25h16.5" />
                </svg>
            </GzButton>

            @* Column Visibility Toggle *@
            <div class="relative">
                <GzButton Variant="ComponentVariant.Ghost" Size="ComponentSize.Icon"
                          aria-label="Toggle columns"
                          OnClick="() => _showColumnMenu = !_showColumnMenu">
                    <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6h9.75M10.5 6a1.5 1.5 0 11-3 0m3 0a1.5 1.5 0 10-3 0M3.75 6H7.5m3 12h9.75m-9.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-3.75 0H7.5m9-6h3.75m-3.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-9.75 0h9.75" />
                    </svg>
                </GzButton>
                @if (_showColumnMenu)
                {
                    <div class="absolute end-0 top-full z-50 mt-1 w-48 rounded-md border border-border/50 bg-popover p-2 shadow-lg">
                        <p class="mb-2 px-2 text-xs font-medium uppercase tracking-widest text-muted-foreground">Columns</p>
                        @foreach (var col in Columns)
                        {
                            <label class="flex cursor-pointer items-center gap-2 rounded-sm px-2 py-1.5 text-sm text-foreground transition-colors hover:bg-accent/50">
                                <input type="checkbox" checked="@col.Visible"
                                       class="accent-primary size-3.5"
                                       @onchange="() => ToggleColumn(col)" />
                                @col.Header
                            </label>
                        }
                    </div>
                }
            </div>

            @* CSV Export *@
            @if (Exportable)
            {
                <GzButton Variant="ComponentVariant.Ghost" Size="ComponentSize.Icon"
                          aria-label="Export CSV"
                          OnClick="ExportCsv">
                    <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
                    </svg>
                </GzButton>
            }
        </div>
    </div>

    @* ─── Table ───────────────────────────── *@
    <div class="overflow-x-auto">
        <table class="w-full text-sm">
            <thead class="@(_stickyHeader ? "sticky top-0 z-10" : "")">
                <tr class="border-b border-border/50 bg-muted/50">
                    @if (Selectable)
                    {
                        <th class="@DensityPadding text-center" style="width:48px">
                            <input type="checkbox"
                                   class="accent-primary size-3.5"
                                   checked="@_allSelected"
                                   @onchange="ToggleSelectAll" />
                        </th>
                    }
                    @foreach (var col in VisibleColumns)
                    {
                        <th class="@HeaderCellClass(col)"
                            style="@(col.Width is not null ? $"width:{col.Width}" : "")"
                            @onclick="() => HandleSort(col)">
                            <div class="flex items-center gap-1.5">
                                <span>@col.Header</span>
                                @if (col.Sortable && _sortColumn == col)
                                {
                                    <svg class="size-3.5 text-muted-foreground" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="@(_sortDirection == SortDirection.Ascending ? "M4.5 15.75l7.5-7.5 7.5 7.5" : "M19.5 8.25l-7.5 7.5-7.5-7.5")" />
                                    </svg>
                                }
                            </div>
                        </th>
                    }
                </tr>
            </thead>
            <tbody>
                @if (Loading)
                {
                    @for (var s = 0; s < PageSize; s++)
                    {
                        <tr class="border-b border-border/30 last:border-0">
                            @if (Selectable)
                            {
                                <td class="@DensityPadding text-center"><GzSkeleton class="size-3.5 mx-auto rounded" /></td>
                            }
                            @foreach (var col in VisibleColumns)
                            {
                                <td class="@DensityPadding"><GzSkeleton class="h-4 w-3/4 rounded" /></td>
                            }
                        </tr>
                    }
                }
                else if (_pagedItems.Count == 0)
                {
                    <tr>
                        <td colspan="@(VisibleColumns.Count + (Selectable ? 1 : 0))" class="px-4 py-16 text-center">
                            <div class="flex flex-col items-center gap-3">
                                <svg class="size-12 text-muted-foreground/40" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5m6 4.125l2.25 2.25m0 0l2.25 2.25M12 13.875l2.25-2.25M12 13.875l-2.25 2.25M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z" />
                                </svg>
                                <p class="text-sm text-muted-foreground">
                                    @(string.IsNullOrEmpty(_filterText) ? "No data available" : $"No results for \"{_filterText}\"")
                                </p>
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var item in _pagedItems)
                    {
                        var key = GetItemKey(item);
                        var isSelected = _selectedKeys.Contains(key);
                        <tr class="@RowClass(isSelected)" @onclick="() => HandleRowClick(item)">
                            @if (Selectable)
                            {
                                <td class="@DensityPadding text-center" @onclick:stopPropagation="true">
                                    <input type="checkbox"
                                           class="accent-primary size-3.5"
                                           checked="@isSelected"
                                           @onchange="() => ToggleRow(key)" />
                                </td>
                            }
                            @foreach (var col in VisibleColumns)
                            {
                                <td class="@CellClass(col)">@(col.Field(item)?.ToString())</td>
                            }
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    @* ─── Footer / Pagination ────────────── *@
    <div class="relative flex flex-wrap items-center justify-between gap-3 overflow-visible border-t border-border/30 px-4 py-3 text-sm text-muted-foreground">
        <div class="flex items-center gap-2">
            <span>Rows per page</span>
            <div class="w-[70px]">
                <GzSelect Options="@_pageSizeSelectOptions"
                          Value="@_effectivePageSize.ToString()"
                          ValueChanged="HandlePageSizeSelect"
                          Size="ComponentSize.Sm" />
            </div>
        </div>

        <span>Page @_currentPage of @_totalPages (@_filteredItems.Count items)</span>

        <GzPagination CurrentPage="_currentPage"
                      TotalPages="_totalPages"
                      SiblingCount="1"
                      CurrentPageChanged="HandlePageChanged" />
    </div>

    @* ─── CSV Download Anchor (hidden) ──── *@
    @if (!string.IsNullOrEmpty(_csvDataUrl))
    {
        <a id="gz-csv-download" href="@_csvDataUrl" download="export.csv" class="hidden">Download</a>
    }
</div>

@code {
    // ─── Parameters ─────────────────────────────────
    /// <summary>Data source.</summary>
    [Parameter] public List<TItem> Items { get; set; } = new();

    /// <summary>Column definitions.</summary>
    [Parameter] public List<DataTableColumn<TItem>> Columns { get; set; } = new();

    /// <summary>Default rows per page.</summary>
    [Parameter] public int PageSize { get; set; } = 10;

    /// <summary>Whether to show the filter input.</summary>
    [Parameter] public bool Filterable { get; set; } = true;

    /// <summary>Filter input placeholder text.</summary>
    [Parameter] public string FilterPlaceholder { get; set; } = "Search...";

    /// <summary>Custom filter function. Receives item + filter text, returns true to include.</summary>
    [Parameter] public Func<TItem, string, bool>? FilterFunc { get; set; }

    /// <summary>Whether row selection checkboxes are shown.</summary>
    [Parameter] public bool Selectable { get; set; }

    /// <summary>Whether CSV export button is shown.</summary>
    [Parameter] public bool Exportable { get; set; }

    /// <summary>Whether the table is in loading state.</summary>
    [Parameter] public bool Loading { get; set; }

    /// <summary>Sticky header on scroll.</summary>
    [Parameter] public bool StickyHeader { get => _stickyHeader; set => _stickyHeader = value; }

    /// <summary>Custom key selector for row identity. Defaults to item.GetHashCode().</summary>
    [Parameter] public Func<TItem, object>? KeySelector { get; set; }

    /// <summary>Callback when a row is clicked.</summary>
    [Parameter] public EventCallback<TItem> OnRowClick { get; set; }

    /// <summary>Callback when selection changes. Receives list of selected items.</summary>
    [Parameter] public EventCallback<List<TItem>> OnSelectionChanged { get; set; }

    /// <summary>Additional HTML attributes.</summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    // ─── State ──────────────────────────────────────
    private string _filterText = string.Empty;
    private DataTableColumn<TItem>? _sortColumn;
    private SortDirection _sortDirection = SortDirection.None;
    private int _currentPage = 1;
    private int _effectivePageSize;
    private bool _showColumnMenu;
    private bool _stickyHeader;
    private int _density; // 0=compact, 1=normal, 2=comfortable
    private string? _csvDataUrl;

    private List<TItem> _filteredItems = new();
    private List<TItem> _pagedItems = new();
    private int _totalPages = 1;
    private HashSet<object> _selectedKeys = new();
    private bool _allSelected;

    private readonly int[] _pageSizeOptions = { 5, 10, 25, 50, 100 };

    private List<DataTableColumn<TItem>> VisibleColumns => Columns.Where(c => c.Visible).ToList();

    protected override void OnInitialized()
    {
        _effectivePageSize = PageSize > 0 ? PageSize : 10;
        _density = 1;
    }

    protected override void OnParametersSet() => Recalculate();

    // ─── Core Logic ─────────────────────────────────
    private void Recalculate()
    {
        // Filter
        if (!string.IsNullOrWhiteSpace(_filterText))
        {
            if (FilterFunc is not null)
            {
                _filteredItems = Items.Where(i => FilterFunc(i, _filterText)).ToList();
            }
            else
            {
                var lower = _filterText.ToLowerInvariant();
                _filteredItems = Items.Where(item =>
                    VisibleColumns.Any(col =>
                        col.Field(item)?.ToString()?.Contains(lower, StringComparison.OrdinalIgnoreCase) == true
                    )
                ).ToList();
            }
        }
        else
        {
            _filteredItems = Items.ToList();
        }

        // Sort
        if (_sortColumn is not null && _sortDirection != SortDirection.None)
        {
            _filteredItems = _sortDirection == SortDirection.Ascending
                ? _filteredItems.OrderBy(i => _sortColumn.Field(i)?.ToString()).ToList()
                : _filteredItems.OrderByDescending(i => _sortColumn.Field(i)?.ToString()).ToList();
        }

        // Paginate
        _totalPages = Math.Max(1, (int)Math.Ceiling(_filteredItems.Count / (double)_effectivePageSize));
        _currentPage = Math.Clamp(_currentPage, 1, _totalPages);
        _pagedItems = _filteredItems.Skip((_currentPage - 1) * _effectivePageSize).Take(_effectivePageSize).ToList();

        // Selection state
        _allSelected = _pagedItems.Count > 0 && _pagedItems.All(i => _selectedKeys.Contains(GetItemKey(i)));
    }

    private void HandleFilter(string value)
    {
        _filterText = value;
        _currentPage = 1;
        Recalculate();
    }

    private void HandleSort(DataTableColumn<TItem> col)
    {
        if (!col.Sortable) return;
        if (_sortColumn == col)
        {
            _sortDirection = _sortDirection switch
            {
                SortDirection.Ascending => SortDirection.Descending,
                SortDirection.Descending => SortDirection.None,
                _ => SortDirection.Ascending
            };
            if (_sortDirection == SortDirection.None) _sortColumn = null;
        }
        else
        {
            _sortColumn = col;
            _sortDirection = SortDirection.Ascending;
        }
        Recalculate();
    }

    private void HandlePageSizeChange(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var size))
        {
            _effectivePageSize = size;
            _currentPage = 1;
            Recalculate();
        }
    }

    private void HandlePageSizeSelect(string value)
    {
        if (int.TryParse(value, out var size))
        {
            _effectivePageSize = size;
            _currentPage = 1;
            Recalculate();
        }
    }

    private List<SelectOption> _pageSizeSelectOptions => _pageSizeOptions
        .Select(s => new SelectOption { Value = s.ToString(), Label = s.ToString() })
        .ToList();

    // ─── Pagination ─────────────────────────────────
    private void HandlePageChanged(int page)
    {
        _currentPage = page;
        Recalculate();
    }

    // ─── Column Visibility ──────────────────────────
    private void ToggleColumn(DataTableColumn<TItem> col)
    {
        col.Visible = !col.Visible;
        // Ensure at least one column is visible
        if (!Columns.Any(c => c.Visible))
            col.Visible = true;
        Recalculate();
    }

    // ─── Row Selection ──────────────────────────────
    private object GetItemKey(TItem item) => KeySelector is not null ? KeySelector(item) : item!.GetHashCode();

    private async Task ToggleRow(object key)
    {
        if (_selectedKeys.Contains(key))
            _selectedKeys.Remove(key);
        else
            _selectedKeys.Add(key);

        _allSelected = _pagedItems.All(i => _selectedKeys.Contains(GetItemKey(i)));
        await NotifySelectionChanged();
    }

    private async Task ToggleSelectAll()
    {
        if (_allSelected)
        {
            foreach (var item in _pagedItems)
                _selectedKeys.Remove(GetItemKey(item));
        }
        else
        {
            foreach (var item in _pagedItems)
                _selectedKeys.Add(GetItemKey(item));
        }
        _allSelected = !_allSelected;
        await NotifySelectionChanged();
    }

    private async Task NotifySelectionChanged()
    {
        if (OnSelectionChanged.HasDelegate)
        {
            var selected = Items.Where(i => _selectedKeys.Contains(GetItemKey(i))).ToList();
            await OnSelectionChanged.InvokeAsync(selected);
        }
    }

    // ─── Density ────────────────────────────────────
    private void CycleDensity()
    {
        _density = (_density + 1) % 3;
    }

    private string DensityPadding => _density switch
    {
        0 => "px-3 py-1",
        2 => "px-5 py-4",
        _ => "px-4 py-2.5",
    };

    // ─── CSV Export ─────────────────────────────────
    private void ExportCsv()
    {
        var sb = new System.Text.StringBuilder();
        var visibleCols = VisibleColumns;

        // Header
        sb.AppendLine(string.Join(",", visibleCols.Select(c => EscapeCsv(c.Header))));

        // Rows
        foreach (var item in _filteredItems)
        {
            sb.AppendLine(string.Join(",", visibleCols.Select(c => EscapeCsv(c.Field(item)?.ToString() ?? ""))));
        }

        var base64 = Convert.ToBase64String(System.Text.Encoding.UTF8.GetBytes(sb.ToString()));
        _csvDataUrl = $"data:text/csv;base64,{base64}";
        StateHasChanged();
    }

    private static string EscapeCsv(string value)
    {
        var quote = '"';
        if (value.Contains(',') || value.Contains(quote) || value.Contains('\n'))
            return quote + value.Replace(quote.ToString(), new string(quote, 2)) + quote;
        return value;
    }

    // ─── Row Click ──────────────────────────────────
    private async Task HandleRowClick(TItem item)
    {
        if (OnRowClick.HasDelegate)
            await OnRowClick.InvokeAsync(item);
    }

    // ─── Styling ────────────────────────────────────
    private string ComputedClass => Tw.Merge(
        "rounded-lg border border-border/50 bg-card",
        GetUserClass()
    );

    private string HeaderCellClass(DataTableColumn<TItem> col) => Tw.Merge(
        DensityPadding,
        "text-start font-medium text-foreground",
        col.Sortable ? "cursor-pointer select-none transition-colors duration-150 hover:bg-muted/50" : null,
        col.Class
    );

    private string CellClass(DataTableColumn<TItem> col) => Tw.Merge(
        DensityPadding,
        "text-muted-foreground",
        col.Class
    );

    private string RowClass(bool isSelected) => Tw.Merge(
        "border-b border-border/30 transition-colors duration-150 last:border-0",
        isSelected ? "bg-primary/5" : "hover:bg-muted/30",
        OnRowClick.HasDelegate ? "cursor-pointer" : null
    );

    private string? GetUserClass() =>
        AdditionalAttributes?.TryGetValue("class", out var cls) == true
            ? cls?.ToString() : null;

    private Dictionary<string, object> GetFilteredAttributes()
    {
        if (AdditionalAttributes is null) return new();
        return AdditionalAttributes
            .Where(kvp => !kvp.Key.Equals("class", StringComparison.OrdinalIgnoreCase))
            .ToDictionary(kvp => kvp.Key, kvp => kvp.Value);
    }
}
