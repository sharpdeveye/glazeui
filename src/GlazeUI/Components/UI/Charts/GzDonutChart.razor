@* GzDonutChart — Pie / Donut ring chart with legend and center content.
   Pure SVG arcs rendered from C#. Self-contained HTML tooltips. *@

<div @attributes="GetFilteredAttributes()" class="@ComputedClass">
    @if (Data is not null && Data.Count > 0)
    {
        var total = Data.Sum(d => Math.Abs(d.Value));
        var slices = ComputeSlices(total);

        <div class="flex flex-col items-center gap-4 sm:flex-row sm:items-start sm:gap-6">
            @* Ring *@
            <div class="relative inline-flex shrink-0">
                <svg width="@Size" height="@Size" viewBox="0 0 @Size @Size" role="img" aria-label="@AriaLabel">
                    @foreach (var s in slices)
                    {
                        <path d="@s.Path" fill="@s.Color"
                              class="transition-all duration-300 ease-out opacity-90 hover:opacity-100"
                              stroke="var(--color-background)" stroke-width="2" />
                    }
                </svg>

                @* Tooltip overlay — positioned over each slice's midpoint *@
                <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
                    @foreach (var s in slices)
                    {
                        var cx = Size / 2.0;
                        var cy = Size / 2.0;
                        var outerR = (Size - 4) / 2.0;
                        var midR = InnerRadius > 0 ? outerR * (1 + InnerRadius) / 2 : outerR * 0.65;
                        var midAngle = s.StartDeg + s.SweepDeg / 2;
                        var rad = midAngle * Math.PI / 180;
                        var mx = cx + midR * Math.Cos(rad);
                        var my = cy + midR * Math.Sin(rad);
                        var leftPct = (mx / Size * 100).ToString(Inv);
                        var topPct = (my / Size * 100).ToString(Inv);

                        <div class="group absolute pointer-events-auto cursor-pointer"
                             style="left: @(leftPct)%; top: @(topPct)%; transform: translate(-50%, -50%);">
                            <div class="size-6 rounded-full"></div>
                            <div role="tooltip"
                                 class="pointer-events-none absolute bottom-full left-1/2 mb-2 -translate-x-1/2 whitespace-nowrap rounded-md bg-foreground px-3 py-1.5 text-xs text-background shadow-md invisible opacity-0 transition-all duration-150 ease-out group-hover:visible group-hover:opacity-100 z-50">
                                <span class="inline-block size-2 rounded-full me-1.5 align-middle" style="background-color: @s.Color;"></span>@s.Label: @s.Value.ToString("N0") (@s.Pct.ToString("F1")%)
                            </div>
                        </div>
                    }
                </div>

                @* Center content *@
                @if (CenterContent is not null || ShowTotal)
                {
                    <div class="absolute inset-0 flex flex-col items-center justify-center pointer-events-none">
                        @if (CenterContent is not null)
                        {
                            @CenterContent
                        }
                        else if (ShowTotal)
                        {
                            <span class="text-2xl font-bold text-foreground tabular-nums">@total.ToString("N0")</span>
                            <span class="text-xs text-muted-foreground">Total</span>
                        }
                    </div>
                }
            </div>

            @* Legend *@
            @if (ShowLegend)
            {
                <div class="flex flex-col gap-2">
                    @foreach (var s in slices)
                    {
                        <div class="flex items-center gap-2 text-sm">
                            <span class="inline-block size-3 shrink-0 rounded-full" style="background-color: @s.Color;"></span>
                            <span class="text-muted-foreground">@s.Label</span>
                            <span class="ms-auto font-medium tabular-nums text-foreground">@s.Value.ToString("N0")</span>
                        </div>
                    }
                </div>
            }
        </div>
    }
    else
    {
        @* Empty state *@
        <div class="flex items-center justify-center text-sm text-muted-foreground" style="height: @(Size)px;">
            No data
        </div>
    }
</div>

@code {
    [Parameter] public List<ChartDataPoint>? Data { get; set; }

    /// <summary>0 = full pie, 0.6 = typical donut. Ratio of inner radius to outer.</summary>
    [Parameter] public double InnerRadius { get; set; } = 0.6;

    [Parameter] public int Size { get; set; } = 200;
    [Parameter] public bool ShowLegend { get; set; } = true;
    [Parameter] public bool ShowTotal { get; set; } = true;
    [Parameter] public RenderFragment? CenterContent { get; set; }
    [Parameter] public string AriaLabel { get; set; } = "Donut chart";

    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private static readonly System.Globalization.CultureInfo Inv = System.Globalization.CultureInfo.InvariantCulture;

    private static readonly string[] ChartColors = {
        "var(--color-chart-1)", "var(--color-chart-2)", "var(--color-chart-3)",
        "var(--color-chart-4)", "var(--color-chart-5)"
    };

    private record struct Slice(string Path, string Color, string Label, double Value, double Pct, double StartDeg, double SweepDeg);

    private List<Slice> ComputeSlices(double total)
    {
        if (Data is null || total == 0) return new();

        var cx = Size / 2.0;
        var cy = Size / 2.0;
        var outerR = (Size - 4) / 2.0;
        var innerR = outerR * InnerRadius;
        var slices = new List<Slice>();
        var startAngle = -90.0;

        for (var i = 0; i < Data.Count; i++)
        {
            var d = Data[i];
            var pct = Math.Abs(d.Value) / total * 100;
            var sweep = Math.Abs(d.Value) / total * 360;
            var endAngle = startAngle + sweep;
            var color = d.Color ?? ChartColors[i % ChartColors.Length];

            // Handle single-item full circle edge case
            string path;
            if (Data.Count == 1)
            {
                path = BuildFullCirclePath(cx, cy, outerR, innerR);
            }
            else
            {
                path = BuildArcPath(cx, cy, outerR, innerR, startAngle, endAngle);
            }

            slices.Add(new Slice(path, color, d.Label, d.Value, pct, startAngle, sweep));
            startAngle = endAngle;
        }
        return slices;
    }

    private string BuildFullCirclePath(double cx, double cy, double outerR, double innerR)
    {
        if (InnerRadius == 0)
        {
            return $"M{cx.ToString(Inv)},{(cy - outerR).ToString(Inv)} " +
                   $"A{outerR.ToString(Inv)},{outerR.ToString(Inv)} 0 1 1 {cx.ToString(Inv)},{(cy + outerR).ToString(Inv)} " +
                   $"A{outerR.ToString(Inv)},{outerR.ToString(Inv)} 0 1 1 {cx.ToString(Inv)},{(cy - outerR).ToString(Inv)} Z";
        }

        return $"M{cx.ToString(Inv)},{(cy - outerR).ToString(Inv)} " +
               $"A{outerR.ToString(Inv)},{outerR.ToString(Inv)} 0 1 1 {cx.ToString(Inv)},{(cy + outerR).ToString(Inv)} " +
               $"A{outerR.ToString(Inv)},{outerR.ToString(Inv)} 0 1 1 {cx.ToString(Inv)},{(cy - outerR).ToString(Inv)} Z " +
               $"M{cx.ToString(Inv)},{(cy - innerR).ToString(Inv)} " +
               $"A{innerR.ToString(Inv)},{innerR.ToString(Inv)} 0 1 0 {cx.ToString(Inv)},{(cy + innerR).ToString(Inv)} " +
               $"A{innerR.ToString(Inv)},{innerR.ToString(Inv)} 0 1 0 {cx.ToString(Inv)},{(cy - innerR).ToString(Inv)} Z";
    }

    private string BuildArcPath(double cx, double cy, double outerR, double innerR,
                                double startDeg, double endDeg)
    {
        var sweepDeg = endDeg - startDeg;
        var largeArc = sweepDeg > 180 ? 1 : 0;

        var outerStart = PolarToCart(cx, cy, outerR, startDeg);
        var outerEnd = PolarToCart(cx, cy, outerR, endDeg);
        var innerStart = PolarToCart(cx, cy, innerR, endDeg);
        var innerEnd = PolarToCart(cx, cy, innerR, startDeg);

        if (InnerRadius == 0)
        {
            return $"M{cx.ToString(Inv)},{cy.ToString(Inv)} " +
                   $"L{outerStart.x.ToString(Inv)},{outerStart.y.ToString(Inv)} " +
                   $"A{outerR.ToString(Inv)},{outerR.ToString(Inv)} 0 {largeArc} 1 {outerEnd.x.ToString(Inv)},{outerEnd.y.ToString(Inv)} Z";
        }

        return $"M{outerStart.x.ToString(Inv)},{outerStart.y.ToString(Inv)} " +
               $"A{outerR.ToString(Inv)},{outerR.ToString(Inv)} 0 {largeArc} 1 {outerEnd.x.ToString(Inv)},{outerEnd.y.ToString(Inv)} " +
               $"L{innerStart.x.ToString(Inv)},{innerStart.y.ToString(Inv)} " +
               $"A{innerR.ToString(Inv)},{innerR.ToString(Inv)} 0 {largeArc} 0 {innerEnd.x.ToString(Inv)},{innerEnd.y.ToString(Inv)} Z";
    }

    private static (double x, double y) PolarToCart(double cx, double cy, double r, double deg)
    {
        var rad = deg * Math.PI / 180;
        return (cx + r * Math.Cos(rad), cy + r * Math.Sin(rad));
    }

    private string ComputedClass => Tw.Merge(
        "w-full",
        GetUserClass()
    );

    private string? GetUserClass() =>
        AdditionalAttributes?.TryGetValue("class", out var cls) == true
            ? cls?.ToString() : null;

    private Dictionary<string, object> GetFilteredAttributes()
    {
        if (AdditionalAttributes is null) return new();
        return AdditionalAttributes
            .Where(kvp => !kvp.Key.Equals("class", StringComparison.OrdinalIgnoreCase))
            .ToDictionary(kvp => kvp.Key, kvp => kvp.Value);
    }
}
