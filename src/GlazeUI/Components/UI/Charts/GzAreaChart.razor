@* GzAreaChart — Multi-series line chart with gradient fills.
   Pure SVG. Supports curved/linear lines, dots, grid, labels.
   Self-contained tooltips via HTML overlay. *@

<div @attributes="GetFilteredAttributes()" class="@ComputedClass">
    @if (Series is not null && Series.Count > 0 && Series[0].Values.Count > 0)
    {
        var m = ComputeMetrics();

        <div class="relative w-full">
            <svg class="block w-full" viewBox="0 0 @m.SvgW @m.SvgH"
                 preserveAspectRatio="xMidYMid meet" role="img" aria-label="@AriaLabel">

                <defs>
                    @for (var si = 0; si < Series.Count; si++)
                    {
                        var gradId = $"{_uid}-grad-{si}";
                        var color = Series[si].Color ?? ChartColors[si % ChartColors.Length];
                        <linearGradient id="@gradId" x1="0" y1="0" x2="0" y2="1">
                            <stop offset="0%" stop-color="@color" stop-opacity="0.25" />
                            <stop offset="100%" stop-color="@color" stop-opacity="0.02" />
                        </linearGradient>
                    }
                </defs>

                @* Grid *@
                @if (ShowGrid)
                {
                    @for (var g = 0; g <= 4; g++)
                    {
                        var gy = m.PlotY + m.PlotH * g / 4.0;
                        <line x1="@m.PlotX.ToString(Inv)" y1="@gy.ToString(Inv)"
                              x2="@((m.PlotX + m.PlotW).ToString(Inv))" y2="@gy.ToString(Inv)"
                              stroke="var(--color-border)" stroke-opacity="0.3" stroke-dasharray="4 4" />
                    }
                }

                @* X-axis labels *@
                @if (ShowLabels && Labels is not null)
                {
                    var labelStep = Math.Max(1, Labels.Count / 6);
                    @for (var i = 0; i < Labels.Count; i += labelStep)
                    {
                        var lx = m.PlotX + (m.PlotW * i / Math.Max(1, Labels.Count - 1));
                        @SvgText(lx.ToString(Inv), (m.PlotY + m.PlotH + 16).ToString(Inv), "middle", TruncateLabel(Labels[i], 6))
                    }
                }

                @* Series: area fills, then lines, then dots (z-order) *@
                @for (var si = 0; si < Series.Count; si++)
                {
                    var s = Series[si];
                    var pts = ComputeSeriesPoints(s, m);
                    var color = s.Color ?? ChartColors[si % ChartColors.Length];
                    var gradId = $"{_uid}-grad-{si}";

                    @* Area fill *@
                    <path d="@BuildAreaPath(pts, m)" fill="url(#@gradId)"
                          class="transition-all duration-500 ease-out" />

                    @* Line *@
                    <path d="@BuildLinePath(pts)" fill="none"
                          stroke="@color" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                          class="transition-all duration-500 ease-out" />
                }

                @* Dots (rendered last for z-index) *@
                @if (ShowDots)
                {
                    @for (var si = 0; si < Series.Count; si++)
                    {
                        var s = Series[si];
                        var pts = ComputeSeriesPoints(s, m);
                        var color = s.Color ?? ChartColors[si % ChartColors.Length];

                        @foreach (var p in pts)
                        {
                            <circle cx="@p.X.ToString(Inv)" cy="@p.Y.ToString(Inv)"
                                    r="3" fill="var(--color-background)" stroke="@color" stroke-width="2"
                                    class="transition-all duration-200 ease-out" />
                        }
                    }
                }
            </svg>

            @* ─── HTML Tooltip Overlay ──────────────── *@
            @if (ShowDots)
            {
                <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
                    @for (var si = 0; si < Series.Count; si++)
                    {
                        var s = Series[si];
                        var pts = ComputeSeriesPoints(s, m);
                        var color = s.Color ?? ChartColors[si % ChartColors.Length];

                        @foreach (var p in pts)
                        {
                            var leftPct = (p.X / m.SvgW * 100).ToString(Inv);
                            var topPct = (p.Y / m.SvgH * 100).ToString(Inv);

                            <div class="group absolute pointer-events-auto"
                                 style="left: @(leftPct)%; top: @(topPct)%; transform: translate(-50%, -50%);">
                                <div class="size-5 cursor-pointer rounded-full"></div>
                                <div role="tooltip"
                                     class="pointer-events-none absolute bottom-full left-1/2 mb-2 -translate-x-1/2 whitespace-nowrap rounded-md bg-foreground px-3 py-1.5 text-xs text-background shadow-md invisible opacity-0 transition-all duration-150 ease-out group-hover:visible group-hover:opacity-100 z-50">
                                    <span class="inline-block size-2 rounded-full me-1.5 align-middle" style="background-color: @color;"></span>@s.Name — @p.Label: @FormatValue(p.Val)
                                </div>
                            </div>
                        }
                    }
                </div>
            }
        </div>

        @* Legend *@
        @if (ShowLegend && Series.Count > 1)
        {
            <div class="mt-3 flex flex-wrap items-center justify-center gap-4">
                @for (var si = 0; si < Series.Count; si++)
                {
                    var color = Series[si].Color ?? ChartColors[si % ChartColors.Length];
                    <div class="flex items-center gap-1.5 text-xs text-muted-foreground">
                        <span class="inline-block size-2.5 rounded-full" style="background-color: @color;"></span>
                        @Series[si].Name
                    </div>
                }
            </div>
        }
    }
    else
    {
        @* Empty state *@
        <div class="flex items-center justify-center text-sm text-muted-foreground" style="height: @(Height)px;">
            No data
        </div>
    }
</div>

@code {
    [Parameter] public List<ChartSeries>? Series { get; set; }
    [Parameter] public List<string>? Labels { get; set; }
    [Parameter] public bool ShowGrid { get; set; } = true;
    [Parameter] public bool ShowDots { get; set; } = true;
    [Parameter] public bool ShowLabels { get; set; } = true;
    [Parameter] public bool ShowLegend { get; set; } = true;
    [Parameter] public bool Curved { get; set; } = true;
    [Parameter] public int Height { get; set; } = 200;
    [Parameter] public string AriaLabel { get; set; } = "Area chart";

    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private static readonly System.Globalization.CultureInfo Inv = System.Globalization.CultureInfo.InvariantCulture;
    private readonly string _uid = $"gz-area-{Guid.NewGuid().ToString("N")[..6]}";

    private static readonly string[] ChartColors = {
        "var(--color-chart-1)", "var(--color-chart-2)", "var(--color-chart-3)",
        "var(--color-chart-4)", "var(--color-chart-5)"
    };

    private record struct PlotMetrics(double SvgW, double SvgH, double PlotX, double PlotY,
                                      double PlotW, double PlotH, double MinVal, double MaxVal, double Range);

    private record struct ChartPoint(double X, double Y, string Label, double Val);

    private PlotMetrics ComputeMetrics()
    {
        var allVals = Series!.SelectMany(s => s.Values);
        var minVal = allVals.Min();
        var maxVal = allVals.Max();
        if (minVal > 0) minVal = 0;
        var range = maxVal - minVal;
        if (range == 0) range = 1;

        var padLeft = 10.0;
        var padBottom = ShowLabels ? 28.0 : 8.0;
        var padTop = 8.0;
        var svgW = 600.0;
        var plotW = svgW - padLeft - 10;
        var plotH = Height - padTop - padBottom;
        return new(svgW, Height, padLeft, padTop, plotW, plotH, minVal, maxVal, range);
    }

    private List<ChartPoint> ComputeSeriesPoints(ChartSeries s, PlotMetrics m)
    {
        var pts = new List<ChartPoint>(s.Values.Count);
        for (var i = 0; i < s.Values.Count; i++)
        {
            var x = m.PlotX + m.PlotW * i / Math.Max(1, s.Values.Count - 1);
            var y = m.PlotY + m.PlotH - (s.Values[i] - m.MinVal) / m.Range * m.PlotH;
            var label = Labels is not null && i < Labels.Count ? Labels[i] : i.ToString();
            pts.Add(new ChartPoint(x, y, label, s.Values[i]));
        }
        return pts;
    }

    private string BuildLinePath(List<ChartPoint> pts)
    {
        if (pts.Count == 0) return "";
        var sb = new System.Text.StringBuilder();
        sb.Append($"M{pts[0].X.ToString(Inv)},{pts[0].Y.ToString(Inv)}");

        for (var i = 1; i < pts.Count; i++)
        {
            if (Curved)
            {
                var cpx = (pts[i - 1].X + pts[i].X) / 2;
                sb.Append($" C{cpx.ToString(Inv)},{pts[i - 1].Y.ToString(Inv)} {cpx.ToString(Inv)},{pts[i].Y.ToString(Inv)} {pts[i].X.ToString(Inv)},{pts[i].Y.ToString(Inv)}");
            }
            else
            {
                sb.Append($" L{pts[i].X.ToString(Inv)},{pts[i].Y.ToString(Inv)}");
            }
        }
        return sb.ToString();
    }

    private string BuildAreaPath(List<ChartPoint> pts, PlotMetrics m)
    {
        if (pts.Count == 0) return "";
        var line = BuildLinePath(pts);
        var bottom = (m.PlotY + m.PlotH).ToString(Inv);
        return $"{line} L{pts[^1].X.ToString(Inv)},{bottom} L{pts[0].X.ToString(Inv)},{bottom} Z";
    }

    private static MarkupString SvgText(string x, string y, string anchor, string content)
    {
        var escaped = System.Web.HttpUtility.HtmlEncode(content);
        return new MarkupString(
            $"<text x=\"{x}\" y=\"{y}\" text-anchor=\"{anchor}\" fill=\"var(--color-muted-foreground)\" " +
            $"font-size=\"11\" font-family=\"var(--font-sans)\" class=\"select-none\">{escaped}</text>"
        );
    }

    private static string TruncateLabel(string label, int max)
    {
        if (label.Length <= max) return label;
        return label[..(max - 1)] + "…";
    }

    private static string FormatValue(double val)
    {
        if (Math.Abs(val) >= 1000) return val.ToString("N0");
        return val.ToString("G4");
    }

    private string ComputedClass => Tw.Merge("w-full", GetUserClass());

    private string? GetUserClass() =>
        AdditionalAttributes?.TryGetValue("class", out var cls) == true
            ? cls?.ToString() : null;

    private Dictionary<string, object> GetFilteredAttributes()
    {
        if (AdditionalAttributes is null) return new();
        return AdditionalAttributes
            .Where(kvp => !kvp.Key.Equals("class", StringComparison.OrdinalIgnoreCase))
            .ToDictionary(kvp => kvp.Key, kvp => kvp.Value);
    }
}
