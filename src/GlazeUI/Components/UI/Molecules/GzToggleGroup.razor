@* GzToggleGroup — Group of exclusive toggles acting as a single-select group *@

<div @attributes="GetFilteredAttributes()"
     role="group"
     class="@ComputedClass">
    @foreach (var item in Items)
    {
        var itemValue = item.Value;
        var isActive = itemValue == Value;
        <button type="button"
                role="radio"
                aria-checked="@isActive.ToString().ToLower()"
                disabled="@Disabled"
                class="@GetItemClass(isActive)"
                @onclick="() => Select(itemValue)">
            @if (item.Icon is not null)
            {
                @item.Icon
            }
            @if (!string.IsNullOrWhiteSpace(item.Label))
            {
                <span>@item.Label</span>
            }
        </button>
    }
</div>

@code {
    /// <summary>Toggle items.</summary>
    [Parameter] public List<ToggleGroupItem> Items { get; set; } = new();

    /// <summary>Currently selected value — supports two-way binding.</summary>
    [Parameter] public string? Value { get; set; }

    /// <summary>Callback when selection changes.</summary>
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }

    /// <summary>Whether the group is disabled.</summary>
    [Parameter] public bool Disabled { get; set; }

    /// <summary>Visual variant.</summary>
    [Parameter] public ComponentVariant Variant { get; set; } = ComponentVariant.Default;

    /// <summary>Additional HTML attributes.</summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string ComputedClass => Tw.Merge(
        "inline-flex items-center gap-1 rounded-lg bg-muted p-1",
        GetUserClass()
    );

    private string GetItemClass(bool isActive) => Tw.Merge(
        "inline-flex items-center justify-center gap-2 rounded-md px-3 py-1.5",
        "text-sm font-medium cursor-pointer",
        "transition-all duration-200 ease-out",
        "focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 ring-offset-background",
        "disabled:pointer-events-none disabled:opacity-50",
        "[&_svg]:size-4 [&_svg]:shrink-0",
        isActive
            ? "bg-background text-foreground shadow-xs"
            : "text-muted-foreground hover:text-foreground hover:bg-background/50"
    );

    private async Task Select(string value)
    {
        if (Disabled) return;
        Value = value;
        await ValueChanged.InvokeAsync(Value);
    }

    private string? GetUserClass() =>
        AdditionalAttributes?.TryGetValue("class", out var cls) == true
            ? cls?.ToString() : null;

    private Dictionary<string, object> GetFilteredAttributes()
    {
        if (AdditionalAttributes is null) return new();
        return AdditionalAttributes
            .Where(kvp => !kvp.Key.Equals("class", StringComparison.OrdinalIgnoreCase))
            .ToDictionary(kvp => kvp.Key, kvp => kvp.Value);
    }
}
