@* GzSidebarMenuBadge — Count badge for menu items. *@

<span data-sidebar="menu-badge" class="@ComputedClass">
    @ChildContent
</span>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string ComputedClass => Tw.Merge(
        "pointer-events-none absolute end-1 top-1/2 -translate-y-1/2 select-none",
        "inline-flex min-w-5 items-center justify-center rounded-full px-1",
        "text-[10px] font-medium tabular-nums leading-none",
        "bg-sidebar-primary text-sidebar-primary-foreground",
        "group-data-[collapsible=icon]:hidden",
        GetUserClass()
    );

    private string? GetUserClass() =>
        AdditionalAttributes?.TryGetValue("class", out var cls) == true
            ? cls?.ToString() : null;
}
