@using GlazeUI.Utilities

<input @attributes="FilteredAttributes"
       type="@Type"
       value="@Value"
       placeholder="@Placeholder"
       disabled="@Disabled"
       readonly="@ReadOnly"
       class="@ComputedClass"
       @oninput="HandleInput" />

@code {
    /// <summary>HTML input type (text, email, password, number, search, tel, url).</summary>
    [Parameter] public string Type { get; set; } = "text";

    /// <summary>Current value — supports two-way binding via @bind-Value.</summary>
    [Parameter] public string? Value { get; set; }

    /// <summary>Callback when value changes — enables @bind-Value.</summary>
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }

    /// <summary>Placeholder text shown when empty.</summary>
    [Parameter] public string? Placeholder { get; set; }

    /// <summary>Whether the input is disabled.</summary>
    [Parameter] public bool Disabled { get; set; }

    /// <summary>Whether the input is read-only.</summary>
    [Parameter] public bool ReadOnly { get; set; }

    /// <summary>Additional HTML attributes passed through to the input element.</summary>
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private const string BaseClasses =
        "flex h-9 w-full rounded-lg border border-input bg-surface px-3 py-1 " +
        "text-sm text-foreground shadow-xs transition-colors " +
        "file:border-0 file:bg-transparent file:text-sm file:font-medium file:text-foreground " +
        "placeholder:text-muted-foreground " +
        "focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ring " +
        "disabled:cursor-not-allowed disabled:opacity-50";

    private string ComputedClass => CssBuilder.Create(BaseClasses)
        .Add(UserClass)
        .Build();

    private string? UserClass => AdditionalAttributes?.TryGetValue("class", out var cls) == true
        ? cls?.ToString()
        : null;

    private Dictionary<string, object>? FilteredAttributes =>
        AdditionalAttributes?.Where(kv => kv.Key != "class")
            .ToDictionary(kv => kv.Key, kv => kv.Value) is { Count: > 0 } filtered
            ? filtered
            : null;

    private async Task HandleInput(ChangeEventArgs e)
    {
        Value = e.Value?.ToString();
        await ValueChanged.InvokeAsync(Value);
    }
}
