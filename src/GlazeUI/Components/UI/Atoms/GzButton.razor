@using GlazeUI.Models
@using GlazeUI.Utilities

<button @attributes="AdditionalAttributes"
        class="@ComputedClass"
        disabled="@Disabled"
        type="@Type"
        @onclick="OnClick">
    @ChildContent
</button>

@code {
    /// <summary>Button content (text, icons, or mixed).</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>Visual style variant.</summary>
    [Parameter] public ButtonVariant Variant { get; set; } = ButtonVariant.Default;

    /// <summary>Size preset.</summary>
    [Parameter] public ButtonSize Size { get; set; } = ButtonSize.Medium;

    /// <summary>Whether the button is disabled.</summary>
    [Parameter] public bool Disabled { get; set; }

    /// <summary>HTML button type attribute.</summary>
    [Parameter] public string Type { get; set; } = "button";

    /// <summary>Click event callback.</summary>
    [Parameter] public EventCallback<MouseEventArgs> OnClick { get; set; }

    /// <summary>Additional HTML attributes passed through to the button element.</summary>
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private const string BaseClasses =
        "inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-lg " +
        "text-sm font-medium transition-all duration-200 " +
        "focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ring " +
        "disabled:pointer-events-none disabled:opacity-50 " +
        "[&_svg]:pointer-events-none [&_svg]:shrink-0";

    private string ComputedClass => CssBuilder.Create(BaseClasses)
        .AddFromEnum(Variant, GetVariantClasses)
        .AddFromEnum(Size, GetSizeClasses)
        .Add(UserClass)
        .Build();

    private string? UserClass => AdditionalAttributes?.TryGetValue("class", out var cls) == true
        ? cls?.ToString()
        : null;

    private static string GetVariantClasses(ButtonVariant variant) => variant switch
    {
        ButtonVariant.Default     => "bg-primary-500 text-white shadow-sm hover:bg-primary-600",
        ButtonVariant.Secondary   => "bg-muted text-foreground shadow-sm hover:bg-muted/80",
        ButtonVariant.Destructive => "bg-destructive text-destructive-foreground shadow-sm hover:bg-destructive/90",
        ButtonVariant.Outline     => "border border-border bg-surface shadow-xs hover:bg-muted hover:text-foreground",
        ButtonVariant.Ghost       => "hover:bg-muted hover:text-foreground",
        ButtonVariant.Link        => "text-primary-500 underline-offset-4 hover:underline",
        _                         => ""
    };

    private static string GetSizeClasses(ButtonSize size) => size switch
    {
        ButtonSize.Small  => "h-8 px-3 text-xs",
        ButtonSize.Medium => "h-9 px-4 py-2",
        ButtonSize.Large  => "h-10 px-6",
        ButtonSize.Icon   => "h-9 w-9",
        _                 => ""
    };
}
