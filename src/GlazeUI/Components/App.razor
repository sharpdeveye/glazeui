<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>GlazeUI — Design System for Blazor + TailwindCSS</title>
    <meta name="description" content="A production-grade design system for Blazor and TailwindCSS. Beautifully designed, fully accessible, you own the code." />
    <base href="/" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="css/app.css" />
    <link rel="stylesheet" href="@Assets["GlazeUI.styles.css"]" />
    <script src="js/glaze-theme.js"></script>
    <ImportMap />
    <HeadOutlet @rendermode="InteractiveServer" />
</head>

<body class="min-h-screen bg-background text-foreground antialiased">
    <Routes @rendermode="InteractiveServer" />
    <script src="_framework/blazor.web.js"></script>
</body>

</html>
