@inherits LayoutComponentBase
@inject IJSRuntime JS

<div class="flex min-h-screen flex-col">
    @* --- Header / Navigation --- *@
    <header class="sticky top-0 z-50 w-full border-b border-border/50 bg-surface/80 backdrop-blur-md">
        <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
            @* Logo / Brand *@
            <a href="/" class="flex items-center gap-2.5 text-lg font-semibold tracking-tight text-foreground transition-colors hover:text-primary">
                <svg class="size-7" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect width="32" height="32" rx="8" class="fill-primary"/>
                    <path d="M8 22V10h4l4 6 4-6h4v12h-4v-7l-4 5.5L12 15v7H8z" class="fill-primary-foreground"/>
                </svg>
                <span>GlazeUI</span>
            </a>

            @* Navigation *@
            <nav class="hidden items-center gap-6 text-sm font-medium text-muted-foreground md:flex">
                <a href="/" class="transition-colors hover:text-foreground">Home</a>
                <a href="/components" class="transition-colors hover:text-foreground">Components</a>
                <a href="https://github.com/sharpdeveye/glazeui" target="_blank" rel="noopener" class="transition-colors hover:text-foreground">GitHub</a>
            </nav>

            @* Dark Mode Toggle *@
            <button @onclick="ToggleTheme"
                    class="inline-flex size-9 items-center justify-center rounded-lg border border-border/50 bg-surface text-muted-foreground shadow-xs cursor-pointer transition-all duration-200 ease-out active:scale-[0.98] hover:bg-muted hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 ring-offset-background"
                    aria-label="Toggle dark mode">
                @if (_isDark)
                {
                    @* Sun icon *@
                    <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
                    </svg>
                }
                else
                {
                    @* Moon icon *@
                    <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" />
                    </svg>
                }
            </button>
        </div>
    </header>

    @* --- Main Content --- *@
    <main class="flex-1">
        @Body
    </main>

    @* --- Footer --- *@
    <footer class="border-t border-border/50 bg-surface py-8">
        <div class="mx-auto max-w-7xl px-4 text-center text-sm text-muted-foreground sm:px-6 lg:px-8">
            <p>Built with Blazor + TailwindCSS. Licensed under Apache 2.0.</p>
            <p class="mt-1">© 2026 GlazeUI Contributors</p>
        </div>
    </footer>
</div>

@code {
    private bool _isDark;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _isDark = await JS.InvokeAsync<bool>("glazeTheme.get");
            StateHasChanged();
        }
    }

    private async Task ToggleTheme()
    {
        _isDark = await JS.InvokeAsync<bool>("glazeTheme.toggle");
    }
}
