@page "/docs/patterns"

<PageTitle>Pattern Recipes — GlazeUI</PageTitle>
<HeadContent>
    <meta name="description" content="Production-ready patterns composed from GlazeUI components — login forms, settings pages, dashboard cards, and more." />
</HeadContent>

<div class="mx-auto flex max-w-6xl gap-10 px-4 py-12 sm:px-6 lg:px-8">

    @* ─── Sidebar ──────────────────────────────── *@
    <aside class="hidden w-56 shrink-0 lg:block">
        <nav class="sticky top-24 space-y-1">
            <p class="mb-3 text-xs font-medium uppercase tracking-widest text-muted-foreground">Patterns</p>
            <GzSidebarLink Href="/docs/patterns#login" Label="Login Form" />
            <GzSidebarLink Href="/docs/patterns#settings" Label="Settings Page" />
            <GzSidebarLink Href="/docs/patterns#dashboard" Label="Dashboard Cards" />
            <GzSidebarLink Href="/docs/patterns#pricing" Label="Pricing Table" />
            <GzSidebarLink Href="/docs/patterns#empty-state" Label="Empty State" />
        </nav>
    </aside>

    @* ─── Content ──────────────────────────────── *@
    <div class="min-w-0 flex-1">
        <p class="text-sm font-medium text-primary">Documentation</p>
        <h1 class="mt-2 text-3xl font-bold tracking-tight text-foreground sm:text-4xl">
            Pattern Recipes
        </h1>
        <p class="mt-3 max-w-2xl text-lg text-muted-foreground">
            Production-ready patterns composed from GlazeUI components. Copy, paste, customize.
        </p>

        @* ─── Login Form ─────────────────────── *@
        <section id="login" class="mt-12 scroll-mt-24">
            <h2 class="text-xl font-semibold tracking-tight text-foreground">Login Form</h2>
            <GzSeparator class="mt-3 mb-6" />

            <div class="mx-auto max-w-sm">
                <GzCard>
                    <Header>
                        <div class="text-center">
                            <h3 class="text-lg font-semibold text-foreground">Welcome back</h3>
                            <p class="mt-1 text-sm text-muted-foreground">Sign in to your account</p>
                        </div>
                    </Header>
                    <ChildContent>
                        <div class="space-y-4">
                            <GzFormField Label="Email" Id="login-email" Required="true">
                                <GzInput Id="login-email" Type="email" Placeholder="you@example.com" />
                            </GzFormField>
                            <GzFormField Label="Password" Id="login-password" Required="true">
                                <GzInput Id="login-password" Type="password" Placeholder="Enter your password" />
                            </GzFormField>
                            <div class="flex items-center justify-between">
                                <GzCheckbox @bind-Checked="_rememberMe">Remember me</GzCheckbox>
                                <GzButton Variant="ComponentVariant.Link" Size="ComponentSize.Sm">Forgot password?</GzButton>
                            </div>
                            <GzButton class="w-full">Sign in</GzButton>
                            <GzSeparator />
                            <p class="text-center text-sm text-muted-foreground">
                                Don't have an account?
                                <GzButton Variant="ComponentVariant.Link" Size="ComponentSize.Sm">Sign up</GzButton>
                            </p>
                        </div>
                    </ChildContent>
                </GzCard>
            </div>
        </section>

        @* ─── Settings Page ──────────────────── *@
        <section id="settings" class="mt-16 scroll-mt-24">
            <h2 class="text-xl font-semibold tracking-tight text-foreground">Settings Page</h2>
            <GzSeparator class="mt-3 mb-6" />

            <GzTabs Tabs="_settingsTabs" @bind-ActiveTab="_settingsActive" />
        </section>

        @* ─── Dashboard Cards ────────────────── *@
        <section id="dashboard" class="mt-16 scroll-mt-24">
            <h2 class="text-xl font-semibold tracking-tight text-foreground">Dashboard Cards</h2>
            <GzSeparator class="mt-3 mb-6" />

            <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
                <GzCard>
                    <ChildContent>
                        <div class="flex items-center justify-between">
                            <p class="text-sm font-medium text-muted-foreground">Total Revenue</p>
                            <svg class="size-4 text-muted-foreground" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                        </div>
                        <div class="mt-2">
                            <p class="text-2xl font-bold tracking-tight text-foreground">$45,231.89</p>
                            <p class="mt-1 text-xs text-muted-foreground">+20.1% from last month</p>
                        </div>
                    </ChildContent>
                </GzCard>

                <GzCard>
                    <ChildContent>
                        <div class="flex items-center justify-between">
                            <p class="text-sm font-medium text-muted-foreground">Active Users</p>
                            <svg class="size-4 text-muted-foreground" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" /></svg>
                        </div>
                        <div class="mt-2">
                            <p class="text-2xl font-bold tracking-tight text-foreground">+2,350</p>
                            <p class="mt-1 text-xs text-muted-foreground">+180.1% from last month</p>
                        </div>
                    </ChildContent>
                </GzCard>

                <GzCard>
                    <ChildContent>
                        <div class="flex items-center justify-between">
                            <p class="text-sm font-medium text-muted-foreground">Conversion Rate</p>
                            <svg class="size-4 text-muted-foreground" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941" /></svg>
                        </div>
                        <div class="mt-2">
                            <p class="text-2xl font-bold tracking-tight text-foreground">12.5%</p>
                            <p class="mt-1 text-xs text-muted-foreground">+2.4% from last month</p>
                        </div>
                    </ChildContent>
                </GzCard>
            </div>

            <div class="mt-4">
                <GzCard>
                    <Header><h3 class="font-semibold text-foreground">Recent Activity</h3></Header>
                    <ChildContent>
                        <div class="space-y-4">
                            @foreach (var activity in _recentActivity)
                            {
                                <div class="flex items-center gap-4">
                                    <GzAvatar Initials="@activity.Initials" Size="ComponentSize.Sm" />
                                    <div class="min-w-0 flex-1">
                                        <p class="text-sm font-medium text-foreground">@activity.Name</p>
                                        <p class="text-xs text-muted-foreground">@activity.Action</p>
                                    </div>
                                    <GzBadge Variant="@activity.BadgeVariant">@activity.Status</GzBadge>
                                </div>
                            }
                        </div>
                    </ChildContent>
                </GzCard>
            </div>
        </section>

        @* ─── Pricing Table ────────────────────── *@
        <section id="pricing" class="mt-16 scroll-mt-24">
            <h2 class="text-xl font-semibold tracking-tight text-foreground">Pricing Table</h2>
            <GzSeparator class="mt-3 mb-6" />

            <div class="grid gap-6 sm:grid-cols-3">
                @foreach (var plan in _pricingPlans)
                {
                    <GzCard class="@(plan.Featured ? "border-primary/50 shadow-md" : "")">
                        <ChildContent>
                            <div class="space-y-4">
                                <div>
                                    @if (plan.Featured)
                                    {
                                        <GzBadge class="mb-2">Most Popular</GzBadge>
                                    }
                                    <h3 class="text-lg font-semibold text-foreground">@plan.Name</h3>
                                    <p class="text-sm text-muted-foreground">@plan.Description</p>
                                </div>
                                <div>
                                    <span class="text-3xl font-bold tracking-tight text-foreground">$@plan.Price</span>
                                    <span class="text-sm text-muted-foreground">/month</span>
                                </div>
                                <GzSeparator />
                                <ul class="space-y-2 text-sm text-muted-foreground">
                                    @foreach (var feature in plan.Features)
                                    {
                                        <li class="flex items-center gap-2">
                                            <svg class="size-4 shrink-0 text-primary" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                                            @feature
                                        </li>
                                    }
                                </ul>
                                <GzButton class="w-full" Variant="@(plan.Featured ? ComponentVariant.Default : ComponentVariant.Outline)">
                                    Get started
                                </GzButton>
                            </div>
                        </ChildContent>
                    </GzCard>
                }
            </div>
        </section>

        @* ─── Empty State ────────────────────── *@
        <section id="empty-state" class="mt-16 scroll-mt-24 mb-8">
            <h2 class="text-xl font-semibold tracking-tight text-foreground">Empty State</h2>
            <GzSeparator class="mt-3 mb-6" />

            <GzCard>
                <ChildContent>
                    <div class="flex flex-col items-center py-12 text-center">
                        <div class="rounded-full bg-muted p-4">
                            <svg class="size-8 text-muted-foreground" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" /></svg>
                        </div>
                        <h3 class="mt-4 text-lg font-semibold text-foreground">No projects yet</h3>
                        <p class="mt-2 max-w-sm text-sm text-muted-foreground">Get started by creating your first project. It only takes a minute.</p>
                        <GzButton class="mt-6">
                            <Icon>
                                <svg fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
                            </Icon>
                            <ChildContent>Create project</ChildContent>
                        </GzButton>
                    </div>
                </ChildContent>
            </GzCard>
        </section>
    </div>
</div>

@code {
    private bool _rememberMe;
    private string? _settingsActive;
    private bool _settingsNotif = true;
    private bool _settingsMarketing;

    private List<TabItem> _settingsTabs = new();

    private record ActivityItem(string Initials, string Name, string Action, string Status, ComponentVariant BadgeVariant);

    private readonly List<ActivityItem> _recentActivity = new()
    {
        new("JD", "John Doe", "Created new project", "New", ComponentVariant.Default),
        new("AS", "Alice Smith", "Updated billing info", "Updated", ComponentVariant.Secondary),
        new("BW", "Bob Wilson", "Submitted support ticket", "Pending", ComponentVariant.Outline),
        new("CL", "Carol Lee", "Deleted staging environment", "Deleted", ComponentVariant.Destructive),
    };

    private record PricingPlan(string Name, string Description, int Price, bool Featured, string[] Features);

    private readonly List<PricingPlan> _pricingPlans = new()
    {
        new("Starter", "For individuals and small projects.", 0, false, new[] { "3 projects", "1 GB storage", "Community support", "Basic analytics" }),
        new("Pro", "For growing teams and businesses.", 29, true, new[] { "Unlimited projects", "100 GB storage", "Priority support", "Advanced analytics", "Custom domains", "Team collaboration" }),
        new("Enterprise", "For large organizations.", 99, false, new[] { "Everything in Pro", "Unlimited storage", "24/7 phone support", "SSO & SAML", "Custom integrations", "SLA guarantee" }),
    };

    protected override void OnInitialized()
    {
        _settingsTabs = new List<TabItem>
        {
            new TabItem
            {
                Key = "profile",
                Label = "Profile",
                Content = @<div class="space-y-4">
                    <GzFormField Label="Display name" Id="s-name" Description="This is how your name appears across the platform.">
                        <GzInput Id="s-name" Placeholder="Jane Doe" />
                    </GzFormField>
                    <GzFormField Label="Bio" Id="s-bio" Description="Brief description for your profile. Max 160 characters.">
                        <GzTextarea Id="s-bio" Placeholder="Software engineer who loves building tools..." Rows="3" />
                    </GzFormField>
                    <GzButton Size="ComponentSize.Sm">Update profile</GzButton>
                </div>
            },
            new TabItem
            {
                Key = "notifications",
                Label = "Notifications",
                Content = @<div class="space-y-4">
                    <GzSwitch @bind-Checked="_settingsNotif">Email notifications</GzSwitch>
                    <GzSwitch @bind-Checked="_settingsMarketing">Marketing emails</GzSwitch>
                    <GzSwitch Checked="true" Disabled="true">Security alerts (always on)</GzSwitch>
                    <GzButton Size="ComponentSize.Sm">Save preferences</GzButton>
                </div>
            },
            new TabItem
            {
                Key = "danger",
                Label = "Danger Zone",
                Content = @<div class="space-y-4">
                    <GzAlert Variant="ComponentVariant.Destructive" Title="Delete account">
                        Once you delete your account, there is no going back. All your data will be permanently removed.
                    </GzAlert>
                    <GzButton Variant="ComponentVariant.Destructive" Size="ComponentSize.Sm">Delete my account</GzButton>
                </div>
            }
        };
    }
}
