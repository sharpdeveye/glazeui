        new ComponentInfo("popover", "GzPopover", "Organism", "Click-triggered floating panel for rich content.", new[]
        {
            new PropInfo("Trigger", "RenderFragment?", "null", "Element that toggles the panel"),
            new PropInfo("ChildContent", "RenderFragment?", "null", "Panel content"),
            new PropInfo("Align", "string", "center", "Alignment: start, center, end"),
        }),
    };
}
