        new ComponentInfo("tabs", "GzTabs", "Molecule", "ARIA tablist with lazy panel rendering.", new[]
        {
            new PropInfo("Tabs", "List<TabItem>", "—", "Tab definitions (Key, Label, Content)"),
            new PropInfo("ActiveTab", "string?", "null", "Currently active tab key"),
            new PropInfo("ActiveTabChanged", "EventCallback<string>", "—", "Two-way binding callback"),
        }),
        new ComponentInfo("tooltip", "GzTooltip", "Molecule", "CSS-only tooltip with 4 positions. Zero JS.", new[]
        {
            new PropInfo("Text", "string", "\"\"", "Tooltip text content"),
            new PropInfo("Position", "TooltipPosition", "Top", "Top, Right, Bottom, Left"),
            new PropInfo("ChildContent", "RenderFragment?", "null", "Trigger element"),
        }),
        new ComponentInfo("select", "GzSelect", "Molecule", "Custom dropdown with ARIA combobox and keyboard nav.", new[]
        {
            new PropInfo("Options", "List<SelectOption>", "—", "Available options (Value, Label, Disabled)"),
            new PropInfo("Value", "string?", "null", "Selected option value"),
            new PropInfo("ValueChanged", "EventCallback<string>", "—", "Two-way binding callback"),
            new PropInfo("Placeholder", "string?", "null", "Text when nothing is selected"),
            new PropInfo("Disabled", "bool", "false", "Disables the select"),
        }),
        // Organisms
        new ComponentInfo("dialog", "GzDialog", "Organism", "Modal dialog with backdrop blur and Header/Footer slots.", new[]
        {
            new PropInfo("Open", "bool", "false", "Controls visibility"),
            new PropInfo("OpenChanged", "EventCallback<bool>", "—", "Two-way binding callback"),
            new PropInfo("Title", "string?", "null", "Dialog title text"),
            new PropInfo("Description", "string?", "null", "Optional subtitle"),
            new PropInfo("Size", "DialogSize", "Md", "Sm, Md, Lg, Full"),
            new PropInfo("Header", "RenderFragment?", "null", "Custom header (overrides Title)"),
