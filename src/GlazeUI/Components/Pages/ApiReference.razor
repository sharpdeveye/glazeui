@page "/docs/api"

<PageTitle>API Reference — GlazeUI</PageTitle>
<HeadContent>
    <meta name="description" content="Complete API reference for all 28 GlazeUI components — parameters, types, defaults, and usage notes." />
</HeadContent>

<div class="mx-auto flex max-w-6xl gap-10 px-4 py-12 sm:px-6 lg:px-8">

    @* ─── Sidebar ──────────────────────────────── *@
    <aside class="hidden w-56 shrink-0 lg:block">
        <nav class="sticky top-24 space-y-1">
            <p class="mb-3 text-xs font-medium uppercase tracking-widest text-muted-foreground">Atoms</p>
            <GzSidebarLink Href="/docs/api#button" Label="Button" />
            <GzSidebarLink Href="/docs/api#badge" Label="Badge" />
            <GzSidebarLink Href="/docs/api#input" Label="Input" />
            <GzSidebarLink Href="/docs/api#textarea" Label="Textarea" />
            <GzSidebarLink Href="/docs/api#label" Label="Label" />
            <GzSidebarLink Href="/docs/api#checkbox" Label="Checkbox" />
            <GzSidebarLink Href="/docs/api#switch" Label="Switch" />
            <GzSidebarLink Href="/docs/api#avatar" Label="Avatar" />
            <GzSidebarLink Href="/docs/api#progress" Label="Progress" />

            <p class="mb-2 mt-4 text-xs font-medium uppercase tracking-widest text-muted-foreground">Molecules</p>
            <GzSidebarLink Href="/docs/api#card" Label="Card" />
            <GzSidebarLink Href="/docs/api#alert" Label="Alert" />
            <GzSidebarLink Href="/docs/api#formfield" Label="FormField" />
            <GzSidebarLink Href="/docs/api#tabs" Label="Tabs" />
            <GzSidebarLink Href="/docs/api#tooltip" Label="Tooltip" />
            <GzSidebarLink Href="/docs/api#select" Label="Select" />

            <p class="mb-2 mt-4 text-xs font-medium uppercase tracking-widest text-muted-foreground">Organisms</p>
            <GzSidebarLink Href="/docs/api#dialog" Label="Dialog" />
            <GzSidebarLink Href="/docs/api#dropdown" Label="DropdownMenu" />
            <GzSidebarLink Href="/docs/api#popover" Label="Popover" />
        </nav>
    </aside>

    @* ─── Content ──────────────────────────────── *@
    <div class="min-w-0 flex-1">
        <p class="text-sm font-medium text-primary">Documentation</p>
        <h1 class="mt-2 text-3xl font-bold tracking-tight text-foreground sm:text-4xl">
            API Reference
        </h1>
        <p class="mt-3 max-w-2xl text-lg text-muted-foreground">
            Complete parameter reference for all 28 GlazeUI components. Every component also accepts <code class="rounded bg-muted px-1.5 py-0.5 font-mono text-xs">class</code> and arbitrary HTML attributes via splatting.
        </p>

        @* ─── Shared note ────────────────────── *@
        <GzAlert Variant="AlertVariant.Info" Title="Universal parameters" class="mt-6">
            All components support <code class="rounded bg-muted px-1 py-0.5 font-mono text-xs">class</code> (merged via TwMerge) and <code class="rounded bg-muted px-1 py-0.5 font-mono text-xs">[Parameter(CaptureUnmatchedValues = true)]</code>. These are omitted from individual tables below.
        </GzAlert>

        @foreach (var comp in _components)
        {
            <section id="@comp.Anchor" class="mt-12 scroll-mt-24">
                <div class="flex items-center gap-3">
                    <h2 class="text-xl font-semibold tracking-tight text-foreground">@comp.Name</h2>
                    <GzBadge Variant="BadgeVariant.Outline">@comp.Tier</GzBadge>
                </div>
                <p class="mt-1 text-sm text-muted-foreground">@comp.Description</p>
                <GzSeparator class="mt-3 mb-4" />

                <div class="overflow-x-auto rounded-lg border border-border/50">
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="border-b border-border/50 bg-muted/50">
                                <th class="px-4 py-2 text-start font-medium text-foreground">Parameter</th>
                                <th class="px-4 py-2 text-start font-medium text-foreground">Type</th>
                                <th class="px-4 py-2 text-start font-medium text-foreground">Default</th>
                                <th class="px-4 py-2 text-start font-medium text-foreground">Description</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var prop in comp.Props)
                            {
                                <tr class="border-b border-border/30 last:border-0">
                                    <td class="px-4 py-2 font-mono text-xs text-foreground">@prop.Name</td>
                                    <td class="px-4 py-2 font-mono text-xs text-muted-foreground">@prop.Type</td>
                                    <td class="px-4 py-2 font-mono text-xs text-muted-foreground">@prop.Default</td>
                                    <td class="px-4 py-2 text-muted-foreground">@prop.Description</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        }
    </div>
</div>

@code {
    private record PropInfo(string Name, string Type, string Default, string Description);
    private record ComponentInfo(string Anchor, string Name, string Tier, string Description, PropInfo[] Props);

    private readonly ComponentInfo[] _components = new[]
    {
        new ComponentInfo("button", "GzButton", "Atom", "Interactive button with loading, icon, and 6 variants.", new[]
        {
            new PropInfo("Variant", "ButtonVariant", "Default", "Visual style: Default, Secondary, Destructive, Outline, Ghost, Link"),
            new PropInfo("Size", "ButtonSize", "Md", "Dimensions: Xs, Sm, Md, Lg"),
            new PropInfo("Disabled", "bool", "false", "Disables the button"),
            new PropInfo("Loading", "bool", "false", "Shows spinner and disables interaction"),
            new PropInfo("Type", "string", "button", "HTML button type: button, submit, reset"),
            new PropInfo("OnClick", "EventCallback", "—", "Click handler"),
            new PropInfo("Icon", "RenderFragment?", "null", "Icon slot rendered before label"),
            new PropInfo("ChildContent", "RenderFragment?", "null", "Button label content"),
        }),
        new ComponentInfo("badge", "GzBadge", "Atom", "Status indicator with 4 semantic variants.", new[]
        {
            new PropInfo("Variant", "BadgeVariant", "Default", "Visual style: Default, Secondary, Destructive, Outline"),
            new PropInfo("ChildContent", "RenderFragment?", "null", "Badge text content"),
        }),
        new ComponentInfo("input", "GzInput", "Atom", "Text input with icon slots and validation.", new[]
        {
            new PropInfo("Value", "string?", "null", "Current input value"),
            new PropInfo("ValueChanged", "EventCallback<string>", "—", "Two-way binding callback"),
            new PropInfo("Type", "string", "text", "HTML input type"),
            new PropInfo("Placeholder", "string?", "null", "Placeholder text"),
            new PropInfo("Disabled", "bool", "false", "Disables the input"),
            new PropInfo("ReadOnly", "bool", "false", "Makes input read-only"),
            new PropInfo("Error", "string?", "null", "Validation error message"),
            new PropInfo("Id", "string?", "null", "Element ID for label association"),
            new PropInfo("StartContent", "RenderFragment?", "null", "Leading icon slot"),
            new PropInfo("EndContent", "RenderFragment?", "null", "Trailing icon slot"),
        }),
        new ComponentInfo("textarea", "GzTextarea", "Atom", "Multi-line text input with validation.", new[]
        {
            new PropInfo("Value", "string?", "null", "Current textarea value"),
            new PropInfo("ValueChanged", "EventCallback<string>", "—", "Two-way binding callback"),
            new PropInfo("Placeholder", "string?", "null", "Placeholder text"),
            new PropInfo("Rows", "int", "3", "Visible row count"),
            new PropInfo("Disabled", "bool", "false", "Disables the textarea"),
            new PropInfo("Error", "string?", "null", "Validation error message"),
        }),
        new ComponentInfo("label", "GzLabel", "Atom", "Form label with required indicator.", new[]
        {
            new PropInfo("For", "string?", "null", "ID of the associated form control"),
            new PropInfo("Required", "bool", "false", "Shows red asterisk"),
            new PropInfo("ChildContent", "RenderFragment?", "null", "Label text"),
        }),
        new ComponentInfo("checkbox", "GzCheckbox", "Atom", "Checkbox with SVG checkmark and tactile press.", new[]
        {
            new PropInfo("Checked", "bool", "false", "Current checked state"),
            new PropInfo("CheckedChanged", "EventCallback<bool>", "—", "Two-way binding callback"),
            new PropInfo("Disabled", "bool", "false", "Disables the checkbox"),
            new PropInfo("ChildContent", "RenderFragment?", "null", "Checkbox label"),
        }),
        new ComponentInfo("switch", "GzSwitch", "Atom", "Toggle switch with sliding thumb.", new[]
        {
            new PropInfo("Checked", "bool", "false", "Current toggle state"),
            new PropInfo("CheckedChanged", "EventCallback<bool>", "—", "Two-way binding callback"),
            new PropInfo("Disabled", "bool", "false", "Disables the switch"),
            new PropInfo("ChildContent", "RenderFragment?", "null", "Switch label"),
        }),
        new ComponentInfo("avatar", "GzAvatar", "Atom", "User avatar with image, initials, or default icon.", new[]
        {
            new PropInfo("Src", "string?", "null", "Image URL"),
            new PropInfo("Alt", "string?", "null", "Alt text for image"),
            new PropInfo("Initials", "string?", "null", "1–2 character fallback"),
            new PropInfo("Size", "AvatarSize", "Md", "Dimensions: Sm, Md, Lg"),
        }),
        new ComponentInfo("progress", "GzProgress", "Atom", "Progress bar with 3 sizes.", new[]
        {
            new PropInfo("Value", "int", "0", "Progress percentage (0–100)"),
            new PropInfo("Size", "ComponentSize", "Md", "Bar height: Sm, Md, Lg"),
            new PropInfo("Max", "int", "100", "Maximum value"),
        }),
        // Molecules
        new ComponentInfo("card", "GzCard", "Molecule", "Container with Header, Content, Footer slots.", new[]
        {
            new PropInfo("Header", "RenderFragment?", "null", "Card header slot"),
            new PropInfo("ChildContent", "RenderFragment?", "null", "Card body content"),
            new PropInfo("Footer", "RenderFragment?", "null", "Card footer slot"),
        }),
        new ComponentInfo("alert", "GzAlert", "Molecule", "Semantic alert with auto-icon and 5 variants.", new[]
        {
            new PropInfo("Variant", "AlertVariant", "Default", "Default, Info, Success, Warning, Destructive"),
            new PropInfo("Title", "string?", "null", "Alert heading"),
            new PropInfo("ChildContent", "RenderFragment?", "null", "Alert body text"),
        }),
        new ComponentInfo("formfield", "GzFormField", "Molecule", "Composes Label + Control + Description/Error.", new[]
        {
            new PropInfo("Label", "string", "—", "Field label text"),
            new PropInfo("Id", "string", "—", "ID for label-control association"),
            new PropInfo("Description", "string?", "null", "Help text below the control"),
            new PropInfo("Error", "string?", "null", "Validation error message"),
