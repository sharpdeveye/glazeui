@page "/components"

<PageTitle>Components — GlazeUI</PageTitle>
<HeadContent>
    <meta name="description" content="Browse all 23 GlazeUI components — atoms, molecules, and organisms. Live interactive examples with all variants, sizes, and states." />
</HeadContent>

@* === Page Header === *@
<section class="border-b border-border/50 py-12 sm:py-16">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <p class="text-sm font-medium text-primary">Components</p>
        <h1 class="mt-2 text-3xl font-bold tracking-tight text-foreground sm:text-4xl">
            Component Library
        </h1>
        <p class="mt-3 max-w-2xl text-lg text-muted-foreground">
            23 components across 3 tiers — atoms, molecules, and organisms. Every component ships with semantic tokens, full state coverage, keyboard accessibility, and TailwindMerge class composition.
        </p>
    </div>
</section>

@* === Components with Sidebar === *@
<section class="py-12 sm:py-16">
    <div class="mx-auto flex max-w-6xl gap-10 px-4 sm:px-6 lg:px-8">

        @* ─── Sidebar Nav ─────────────────────── *@
        <aside class="hidden w-48 shrink-0 lg:block">
            <nav class="sticky top-24 space-y-1">
                <p class="mb-2 text-xs font-medium uppercase tracking-widest text-muted-foreground">Atoms</p>
                <a href="#button" class="block rounded-md px-3 py-1 text-sm text-muted-foreground transition-colors hover:text-foreground">Button</a>
                <a href="#badge" class="block rounded-md px-3 py-1 text-sm text-muted-foreground transition-colors hover:text-foreground">Badge</a>
                <a href="#input" class="block rounded-md px-3 py-1 text-sm text-muted-foreground transition-colors hover:text-foreground">Input</a>
                <a href="#textarea" class="block rounded-md px-3 py-1 text-sm text-muted-foreground transition-colors hover:text-foreground">Textarea</a>
                <a href="#checkbox-radio" class="block rounded-md px-3 py-1 text-sm text-muted-foreground transition-colors hover:text-foreground">Checkbox & Radio</a>
                <a href="#switch" class="block rounded-md px-3 py-1 text-sm text-muted-foreground transition-colors hover:text-foreground">Switch</a>
                <a href="#avatar" class="block rounded-md px-3 py-1 text-sm text-muted-foreground transition-colors hover:text-foreground">Avatar</a>
                <a href="#typography" class="block rounded-md px-3 py-1 text-sm text-muted-foreground transition-colors hover:text-foreground">Typography</a>
                <a href="#skeleton" class="block rounded-md px-3 py-1 text-sm text-muted-foreground transition-colors hover:text-foreground">Skeleton</a>
                <a href="#progress" class="block rounded-md px-3 py-1 text-sm text-muted-foreground transition-colors hover:text-foreground">Progress</a>

                <p class="mb-2 mt-4 text-xs font-medium uppercase tracking-widest text-muted-foreground">Molecules</p>
                <a href="#card" class="block rounded-md px-3 py-1 text-sm text-muted-foreground transition-colors hover:text-foreground">Card</a>
                <a href="#alert" class="block rounded-md px-3 py-1 text-sm text-muted-foreground transition-colors hover:text-foreground">Alert</a>
                <a href="#formfield" class="block rounded-md px-3 py-1 text-sm text-muted-foreground transition-colors hover:text-foreground">FormField</a>
                <a href="#tabs" class="block rounded-md px-3 py-1 text-sm text-muted-foreground transition-colors hover:text-foreground">Tabs</a>
                <a href="#tooltip" class="block rounded-md px-3 py-1 text-sm text-muted-foreground transition-colors hover:text-foreground">Tooltip</a>
                <a href="#select" class="block rounded-md px-3 py-1 text-sm text-muted-foreground transition-colors hover:text-foreground">Select</a>

                <p class="mb-2 mt-4 text-xs font-medium uppercase tracking-widest text-muted-foreground">Organisms</p>
                <a href="#dialog" class="block rounded-md px-3 py-1 text-sm text-muted-foreground transition-colors hover:text-foreground">Dialog</a>
                <a href="#dropdown" class="block rounded-md px-3 py-1 text-sm text-muted-foreground transition-colors hover:text-foreground">DropdownMenu</a>
                <a href="#popover" class="block rounded-md px-3 py-1 text-sm text-muted-foreground transition-colors hover:text-foreground">Popover</a>
            </nav>
        </aside>

        @* ─── Component Sections ──────────────── *@
        <div class="min-w-0 flex-1 space-y-16">

        @* ─── Button ─────────────────────────────────── *@
        <div id="button">
            <div class="mb-6">
                <h2 class="text-xl font-semibold tracking-tight text-foreground">Button</h2>
                <p class="mt-1 text-sm text-muted-foreground">6 variants × 4 sizes. Loading state, icon slots, tactile press, and premium inset-shadow depth.</p>
            </div>

            <div class="space-y-8 rounded-xl border border-border/50 bg-card p-6 shadow-xs sm:p-8">
                @* Variants *@
                <div>
                    <p class="mb-3 text-xs font-medium uppercase tracking-widest text-muted-foreground">Variants</p>
                    <div class="flex flex-wrap items-center gap-3">
                        <GzButton>Default</GzButton>
                        <GzButton Variant="ButtonVariant.Secondary">Secondary</GzButton>
                        <GzButton Variant="ButtonVariant.Destructive">Destructive</GzButton>
                        <GzButton Variant="ButtonVariant.Outline">Outline</GzButton>
                        <GzButton Variant="ButtonVariant.Ghost">Ghost</GzButton>
                        <GzButton Variant="ButtonVariant.Link">Link</GzButton>
                    </div>
                </div>

                <GzSeparator />

                @* Sizes *@
                <div>
                    <p class="mb-3 text-xs font-medium uppercase tracking-widest text-muted-foreground">Sizes</p>
                    <div class="flex flex-wrap items-center gap-3">
                        <GzButton Size="ButtonSize.Sm">Small</GzButton>
                        <GzButton Size="ButtonSize.Md">Medium</GzButton>
                        <GzButton Size="ButtonSize.Lg">Large</GzButton>
                        <GzButton Size="ButtonSize.Icon" aria-label="Settings">
                            <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 010 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 010-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28z" />
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                            </svg>
                        </GzButton>
                    </div>
                </div>

                <GzSeparator />

                @* States *@
                <div>
                    <p class="mb-3 text-xs font-medium uppercase tracking-widest text-muted-foreground">States</p>
                    <div class="flex flex-wrap items-center gap-3">
                        <GzButton Disabled="true">Disabled</GzButton>
                        <GzButton Variant="ButtonVariant.Outline" Disabled="true">Disabled Outline</GzButton>
                        <GzButton Loading="true">Loading...</GzButton>
                        <GzButton Variant="ButtonVariant.Secondary" Loading="true">Saving</GzButton>
                        <GzButton Variant="ButtonVariant.Destructive" Loading="true">Deleting</GzButton>
                    </div>
                </div>

                <GzSeparator />

                @* With Icon *@
                <div>
                    <p class="mb-3 text-xs font-medium uppercase tracking-widest text-muted-foreground">With Icon</p>
                    <div class="flex flex-wrap items-center gap-3">
                        <GzButton>
                            <Icon>
                                <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                                </svg>
                            </Icon>
                            <ChildContent>New Project</ChildContent>
                        </GzButton>
                        <GzButton Variant="ButtonVariant.Outline">
                            <Icon>
                                <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
                                </svg>
                            </Icon>
                            <ChildContent>Download</ChildContent>
                        </GzButton>
                    </div>
                </div>
            </div>
        </div>

        @* ─── Badge ──────────────────────────────────── *@
        <div id="badge">
            <div class="mb-6">
                <h2 class="text-xl font-semibold tracking-tight text-foreground">Badge</h2>
                <p class="mt-1 text-sm text-muted-foreground">4 semantic variants for status indicators, labels, and counts. Solid variants feature inset-shadow depth.</p>
            </div>

            <div class="rounded-xl border border-border/50 bg-card p-6 shadow-xs sm:p-8">
                <div class="flex flex-wrap items-center gap-3">
                    <GzBadge>Default</GzBadge>
                    <GzBadge Variant="BadgeVariant.Secondary">Secondary</GzBadge>
                    <GzBadge Variant="BadgeVariant.Destructive">Destructive</GzBadge>
                    <GzBadge Variant="BadgeVariant.Outline">Outline</GzBadge>
                </div>
            </div>
        </div>

        @* ─── Separator ──────────────────────────────── *@
        <div id="separator">
            <div class="mb-6">
                <h2 class="text-xl font-semibold tracking-tight text-foreground">Separator</h2>
                <p class="mt-1 text-sm text-muted-foreground">Subtle dividers with proper ARIA semantics. Decorative by default.</p>
            </div>

            <div class="space-y-6 rounded-xl border border-border/50 bg-card p-6 shadow-xs sm:p-8">
                <div>
                    <p class="mb-3 text-xs font-medium uppercase tracking-widest text-muted-foreground">Horizontal</p>
                    <div class="rounded-lg bg-surface p-4">
                        <p class="text-sm text-foreground">Content above</p>
                        <GzSeparator class="my-3" />
                        <p class="text-sm text-foreground">Content below</p>
                    </div>
                </div>
                <div>
                    <p class="mb-3 text-xs font-medium uppercase tracking-widest text-muted-foreground">Vertical</p>
                    <div class="flex h-8 items-center gap-3 rounded-lg bg-surface px-4">
                        <span class="text-sm text-foreground">Left</span>
                        <GzSeparator Orientation="SeparatorOrientation.Vertical" />
                        <span class="text-sm text-foreground">Center</span>
                        <GzSeparator Orientation="SeparatorOrientation.Vertical" />
                        <span class="text-sm text-foreground">Right</span>
                    </div>
                </div>
            </div>
        </div>

        @* ─── Input + Label ──────────────────────────── *@
        <div id="input">
            <div class="mb-6">
                <h2 class="text-xl font-semibold tracking-tight text-foreground">Input + Label</h2>
                <p class="mt-1 text-sm text-muted-foreground">Text input with inset-ring border, validation states, icon slots, and two-way binding.</p>
            </div>

            <div class="space-y-6 rounded-xl border border-border/50 bg-card p-6 shadow-xs sm:p-8">
                <div class="grid max-w-sm gap-2">
                    <GzLabel For="demo-email" Required="true">Email</GzLabel>
                    <GzInput Id="demo-email" Type="email" Placeholder="you@example.com" />
                </div>

                <div class="grid max-w-sm gap-2">
                    <GzLabel For="demo-password">Password</GzLabel>
                    <GzInput Id="demo-password" Type="password" Placeholder="Enter password" />
                </div>

                <div class="grid max-w-sm gap-2">
                    <GzLabel For="demo-error">With validation error</GzLabel>
                    <GzInput Id="demo-error" Type="email" Value="not-an-email" Error="Please enter a valid email address" />
                </div>

                <div class="grid max-w-sm gap-2">
                    <GzLabel For="demo-disabled">Disabled</GzLabel>
                    <GzInput Id="demo-disabled" Placeholder="Cannot type here" Disabled="true" />
                </div>

                <div class="grid max-w-sm gap-2">
                    <GzLabel For="demo-file">Upload file</GzLabel>
                    <GzInput Id="demo-file" Type="file" />
                </div>
            </div>
        </div>

        @* ─── Textarea ───────────────────────────────── *@
        <div id="textarea">
            <div class="mb-6">
                <h2 class="text-xl font-semibold tracking-tight text-foreground">Textarea</h2>
                <p class="mt-1 text-sm text-muted-foreground">Multi-line input with inset-ring border, validation, and configurable rows.</p>
            </div>

            <div class="space-y-6 rounded-xl border border-border/50 bg-card p-6 shadow-xs sm:p-8">
                <div class="grid max-w-lg gap-2">
                    <GzLabel For="demo-message" Required="true">Message</GzLabel>
                    <GzTextarea Id="demo-message" Placeholder="Tell us what you think..." Rows="4" />
                </div>

                <div class="grid max-w-lg gap-2">
                    <GzLabel For="demo-textarea-error">With validation error</GzLabel>
                    <GzTextarea Id="demo-textarea-error" Value="Too short" Error="Message must be at least 20 characters" />
                </div>

                <div class="grid max-w-lg gap-2">
                    <GzLabel For="demo-readonly">Read-only</GzLabel>
                    <GzTextarea Id="demo-readonly" Value="This content cannot be edited by the user." ReadOnly="true" />
                </div>
            </div>
        </div>

        @* ─── Checkbox ───────────────────────────────── *@
        <div id="checkbox">
            <div class="mb-6">
                <h2 class="text-xl font-semibold tracking-tight text-foreground">Checkbox</h2>
                <p class="mt-1 text-sm text-muted-foreground">Custom checkbox with SVG checkmark, tactile press, and accessible focus ring.</p>
            </div>

            <div class="space-y-4 rounded-xl border border-border/50 bg-card p-6 shadow-xs sm:p-8">
                <GzCheckbox @bind-Checked="_acceptTerms">Accept terms and conditions</GzCheckbox>
                <GzCheckbox @bind-Checked="_newsletter">Subscribe to newsletter</GzCheckbox>
                <GzCheckbox Checked="true" Disabled="true">Disabled (checked)</GzCheckbox>
                <GzCheckbox Checked="false" Disabled="true">Disabled (unchecked)</GzCheckbox>
            </div>
        </div>

        @* ─── Radio ──────────────────────────────────── *@
        <div id="radio">
            <div class="mb-6">
                <h2 class="text-xl font-semibold tracking-tight text-foreground">Radio</h2>
                <p class="mt-1 text-sm text-muted-foreground">Radio buttons with inner dot, group naming, and label support.</p>
            </div>

            <div class="space-y-4 rounded-xl border border-border/50 bg-card p-6 shadow-xs sm:p-8">
                <GzRadio Name="plan" Value="free" Checked="@(_selectedPlan == "free")" CheckedChanged="@(_ => SelectPlan("free"))">Free plan</GzRadio>
                <GzRadio Name="plan" Value="pro" Checked="@(_selectedPlan == "pro")" CheckedChanged="@(_ => SelectPlan("pro"))">Pro plan — $9/mo</GzRadio>
                <GzRadio Name="plan" Value="enterprise" Checked="@(_selectedPlan == "enterprise")" CheckedChanged="@(_ => SelectPlan("enterprise"))">Enterprise — Contact us</GzRadio>
                <GzRadio Name="disabled-group" Value="x" Checked="true" Disabled="true">Disabled (selected)</GzRadio>
            </div>
        </div>

        @* ─── Switch ─────────────────────────────────── *@
        <div id="switch">
            <div class="mb-6">
                <h2 class="text-xl font-semibold tracking-tight text-foreground">Switch</h2>
                <p class="mt-1 text-sm text-muted-foreground">Toggle with sliding thumb, role="switch", and ARIA checked state.</p>
            </div>

            <div class="space-y-4 rounded-xl border border-border/50 bg-card p-6 shadow-xs sm:p-8">
                <GzSwitch @bind-Checked="_notifications">Enable notifications</GzSwitch>
                <GzSwitch @bind-Checked="_analytics">Share analytics</GzSwitch>
                <GzSwitch Checked="true" Disabled="true">Always on (disabled)</GzSwitch>
                <GzSwitch Checked="false" Disabled="true">Always off (disabled)</GzSwitch>
            </div>
        </div>

        @* ─── Avatar ─────────────────────────────────── *@
        <div id="avatar">
            <div class="mb-6">
                <h2 class="text-xl font-semibold tracking-tight text-foreground">Avatar</h2>
                <p class="mt-1 text-sm text-muted-foreground">Circular avatar with image, fallback initials, and default icon. Handles broken images gracefully.</p>
            </div>

            <div class="space-y-6 rounded-xl border border-border/50 bg-card p-6 shadow-xs sm:p-8">
                <div>
                    <p class="mb-3 text-xs font-medium uppercase tracking-widest text-muted-foreground">With image</p>
                    <div class="flex items-center gap-4">
                        <GzAvatar Src="https://api.dicebear.com/9.x/initials/svg?seed=JD" Alt="John Doe" Size="AvatarSize.Sm" />
                        <GzAvatar Src="https://api.dicebear.com/9.x/initials/svg?seed=AS" Alt="Alice Smith" Size="AvatarSize.Md" />
                        <GzAvatar Src="https://api.dicebear.com/9.x/initials/svg?seed=BW" Alt="Bob Wilson" Size="AvatarSize.Lg" />
                    </div>
                </div>
                <div>
                    <p class="mb-3 text-xs font-medium uppercase tracking-widest text-muted-foreground">Initials fallback</p>
                    <div class="flex items-center gap-4">
                        <GzAvatar Initials="JD" Alt="John Doe" Size="AvatarSize.Sm" />
                        <GzAvatar Initials="AS" Alt="Alice Smith" Size="AvatarSize.Md" />
                        <GzAvatar Initials="BW" Alt="Bob Wilson" Size="AvatarSize.Lg" />
                    </div>
                </div>
                <div>
                    <p class="mb-3 text-xs font-medium uppercase tracking-widest text-muted-foreground">Default icon</p>
                    <div class="flex items-center gap-4">
                        <GzAvatar Alt="User" Size="AvatarSize.Sm" />
                        <GzAvatar Alt="User" Size="AvatarSize.Md" />
                        <GzAvatar Alt="User" Size="AvatarSize.Lg" />
                    </div>
                </div>
            </div>
        </div>

        @* ─── Typography ─────────────────────────────── *@
        <div id="typography">
            <div class="mb-6">
                <h2 class="text-xl font-semibold tracking-tight text-foreground">Typography</h2>
                <p class="mt-1 text-sm text-muted-foreground">Semantic HTML elements with predefined typographic scales. Renders correct heading levels, paragraphs, and inline code.</p>
            </div>

            <div class="space-y-4 rounded-xl border border-border/50 bg-card p-6 shadow-xs sm:p-8">
                <GzTypography As="TypographyElement.H1">Heading 1</GzTypography>
                <GzTypography As="TypographyElement.H2">Heading 2</GzTypography>
                <GzTypography As="TypographyElement.H3">Heading 3</GzTypography>
                <GzTypography As="TypographyElement.H4">Heading 4</GzTypography>

                <GzSeparator class="my-4" />

                <GzTypography As="TypographyElement.P">This is a standard paragraph with default leading and foreground color. It's designed for body text and long-form content.</GzTypography>
                <GzTypography As="TypographyElement.Lead">This is a lead paragraph — larger, muted text for introductions.</GzTypography>
                <GzTypography As="TypographyElement.Large">Large text for emphasis</GzTypography>
                <GzTypography As="TypographyElement.Small">Small text for captions</GzTypography>
                <GzTypography As="TypographyElement.Muted">Muted text for secondary information</GzTypography>
                <GzTypography As="TypographyElement.P">Use <GzTypography As="TypographyElement.InlineCode">GzTypography</GzTypography> for consistent text styling.</GzTypography>
            </div>
        </div>

        @* ═══════════════════════════════════════════════ *@
        @* ═══       MOLECULES                        ═══ *@
        @* ═══════════════════════════════════════════════ *@

        <div class="pt-8">
            <GzSeparator />
            <p class="mt-6 text-xs font-medium uppercase tracking-widest text-primary">Molecules</p>
        </div>

        @* ─── Card ────────────────────────────────────── *@
        <div id="card">
            <div class="mb-6">
                <h2 class="text-xl font-semibold tracking-tight text-foreground">Card</h2>
                <p class="mt-1 text-sm text-muted-foreground">Container with optional header, content, and footer slots. Clean border and shadow.</p>
            </div>

            <div class="space-y-6 rounded-xl border border-border/50 bg-card p-6 shadow-xs sm:p-8">
                <div class="grid gap-6 sm:grid-cols-2">
                    @* Basic card *@
                    <GzCard>
                        <Header>
                            <h3 class="text-base font-semibold text-foreground">Card Title</h3>
                            <p class="mt-1 text-sm text-muted-foreground">Card subtitle</p>
                        </Header>
                        <ChildContent>
                            <p class="text-sm text-muted-foreground">This is the card body content. Cards can hold any content — forms, lists, images, or text.</p>
                        </ChildContent>
                        <Footer>
                            <div class="flex justify-end gap-2">
                                <GzButton Variant="ButtonVariant.Ghost" Size="ButtonSize.Sm">Cancel</GzButton>
                                <GzButton Size="ButtonSize.Sm">Save</GzButton>
                            </div>
                        </Footer>
                    </GzCard>

                    @* Content-only card *@
                    <GzCard>
                        <ChildContent>
                            <div class="space-y-3">
                                <h3 class="text-base font-semibold text-foreground">Simple Card</h3>
                                <p class="text-sm text-muted-foreground">A card with content only — no header or footer. Useful for basic containers.</p>
                                <GzBadge Variant="BadgeVariant.Secondary">New</GzBadge>
                            </div>
                        </ChildContent>
                    </GzCard>
                </div>
            </div>
        </div>

        @* ─── Alert ───────────────────────────────────── *@
        <div id="alert">
            <div class="mb-6">
                <h2 class="text-xl font-semibold tracking-tight text-foreground">Alert</h2>
                <p class="mt-1 text-sm text-muted-foreground">5 semantic variants with auto-icons, title, and description. Uses subtle tinted backgrounds.</p>
            </div>

            <div class="space-y-4 rounded-xl border border-border/50 bg-card p-6 shadow-xs sm:p-8">
                <GzAlert Variant="AlertVariant.Default" Title="Default">
                    This is a default alert for general information.
                </GzAlert>
                <GzAlert Variant="AlertVariant.Info" Title="Info">
                    Your workspace is syncing. This may take a few seconds.
                </GzAlert>
                <GzAlert Variant="AlertVariant.Success" Title="Success">
                    Your changes have been saved successfully.
                </GzAlert>
                <GzAlert Variant="AlertVariant.Warning" Title="Warning">
                    Your trial expires in 3 days. Upgrade to keep your data.
                </GzAlert>
                <GzAlert Variant="AlertVariant.Destructive" Title="Error">
                    Failed to deploy. Check your build logs for details.
                </GzAlert>
            </div>
        </div>

        @* ─── FormField ──────────────────────────────── *@
        <div id="formfield">
            <div class="mb-6">
                <h2 class="text-xl font-semibold tracking-tight text-foreground">FormField</h2>
                <p class="mt-1 text-sm text-muted-foreground">Composes label + control + description/error into a single wrapper. Error replaces description when set.</p>
            </div>

            <div class="space-y-6 rounded-xl border border-border/50 bg-card p-6 shadow-xs sm:p-8">
                <div class="max-w-sm">
                    <GzFormField Label="Username" Id="ff-username" Description="This is your public display name." Required="true">
                        <GzInput Id="ff-username" Placeholder="glazeui" />
                    </GzFormField>
                </div>

                <div class="max-w-sm">
                    <GzFormField Label="Email" Id="ff-email" Error="Please enter a valid email address." Required="true">
                        <GzInput Id="ff-email" Type="email" Value="invalid-email" Error="Please enter a valid email address." />
                    </GzFormField>
                </div>

                <div class="max-w-lg">
                    <GzFormField Label="Bio" Id="ff-bio" Description="Write a short introduction about yourself.">
                        <GzTextarea Id="ff-bio" Placeholder="Tell us about yourself..." Rows="3" />
                    </GzFormField>
                </div>
            </div>
        </div>

        @* ─── Skeleton ───────────────────────────────── *@
        <div id="skeleton">
            <div class="mb-6">
                <h2 class="text-xl font-semibold tracking-tight text-foreground">Skeleton</h2>
                <p class="mt-1 text-sm text-muted-foreground">Animated loading placeholders. Line and circle variants. Override dimensions via class.</p>
            </div>

            <div class="space-y-6 rounded-xl border border-border/50 bg-card p-6 shadow-xs sm:p-8">
                <div>
                    <p class="mb-3 text-xs font-medium uppercase tracking-widest text-muted-foreground">Card skeleton</p>
                    <div class="max-w-sm space-y-4 rounded-xl border border-border/50 p-6">
                        <div class="flex items-center gap-3">
                            <GzSkeleton Variant="SkeletonVariant.Circle" />
                            <div class="flex-1 space-y-2">
                                <GzSkeleton class="h-4 w-3/4" />
                                <GzSkeleton class="h-3 w-1/2" />
                            </div>
                        </div>
                        <GzSkeleton class="h-32 w-full" />
                        <div class="space-y-2">
                            <GzSkeleton />
                            <GzSkeleton class="w-4/5" />
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* ─── Progress ───────────────────────────────── *@
        <div id="progress">
            <div class="mb-6">
                <h2 class="text-xl font-semibold tracking-tight text-foreground">Progress</h2>
                <p class="mt-1 text-sm text-muted-foreground">Horizontal progress bar with smooth transition. 3 sizes, proper ARIA progressbar role.</p>
            </div>

            <div class="space-y-6 rounded-xl border border-border/50 bg-card p-6 shadow-xs sm:p-8">
                <div class="max-w-lg space-y-4">
                    <div>
                        <p class="mb-2 text-xs font-medium uppercase tracking-widest text-muted-foreground">Small (25%)</p>
                        <GzProgress Value="25" Size="ProgressSize.Sm" />
                    </div>
                    <div>
                        <p class="mb-2 text-xs font-medium uppercase tracking-widest text-muted-foreground">Medium (60%)</p>
                        <GzProgress Value="60" Size="ProgressSize.Md" />
                    </div>
                    <div>
                        <p class="mb-2 text-xs font-medium uppercase tracking-widest text-muted-foreground">Large (85%)</p>
                        <GzProgress Value="85" Size="ProgressSize.Lg" />
                    </div>
                </div>
            </div>
        </div>

        @* ─── Tabs ────────────────────────────────────── *@
        <div id="tabs">
            <div class="mb-6">
                <h2 class="text-xl font-semibold tracking-tight text-foreground">Tabs</h2>
                <p class="mt-1 text-sm text-muted-foreground">Tab navigation with ARIA tablist/tab/tabpanel pattern. Active tab has elevated background.</p>
            </div>

            <div class="rounded-xl border border-border/50 bg-card p-6 shadow-xs sm:p-8">
                <GzTabs Tabs="_demoPanels" @bind-ActiveTab="_activeTab" />
            </div>
        </div>

        @* ─── Tooltip ─────────────────────────────────── *@
        <div id="tooltip">
            <div class="mb-6">
                <h2 class="text-xl font-semibold tracking-tight text-foreground">Tooltip</h2>
                <p class="mt-1 text-sm text-muted-foreground">CSS-only tooltip with 4 positions. Zero JS, zero SignalR roundtrips — instant on hover and focus.</p>
            </div>

            <div class="rounded-xl border border-border/50 bg-card p-6 shadow-xs sm:p-8">
                <div class="flex flex-wrap items-center gap-6">
                    <GzTooltip Text="Appears on top" Position="TooltipPosition.Top">
                        <GzButton Variant="ButtonVariant.Outline">Top</GzButton>
                    </GzTooltip>
                    <GzTooltip Text="Appears on the right" Position="TooltipPosition.Right">
                        <GzButton Variant="ButtonVariant.Outline">Right</GzButton>
                    </GzTooltip>
                    <GzTooltip Text="Appears on the bottom" Position="TooltipPosition.Bottom">
                        <GzButton Variant="ButtonVariant.Outline">Bottom</GzButton>
                    </GzTooltip>
                    <GzTooltip Text="Appears on the left" Position="TooltipPosition.Left">
                        <GzButton Variant="ButtonVariant.Outline">Left</GzButton>
                    </GzTooltip>
                </div>
            </div>
        </div>

        @* ─── Select ──────────────────────────────────── *@
        <div id="select">
            <div class="mb-6">
                <h2 class="text-xl font-semibold tracking-tight text-foreground">Select</h2>
                <p class="mt-1 text-sm text-muted-foreground">Dropdown select with keyboard navigation (arrow keys, enter, escape), ARIA combobox, and checkmark indicator.</p>
            </div>

            <div class="space-y-6 rounded-xl border border-border/50 bg-card p-6 shadow-xs sm:p-8">
                <div class="max-w-sm">
                    <GzFormField Label="Framework" Id="ff-framework" Description="Your preferred frontend framework.">
                        <GzSelect Options="_frameworkOptions" @bind-Value="_selectedFramework" Placeholder="Select a framework" />
                    </GzFormField>
                </div>
                <div class="max-w-sm">
                    <GzFormField Label="Disabled" Id="ff-disabled-select">
                        <GzSelect Options="_frameworkOptions" Placeholder="Cannot change" Disabled="true" />
                    </GzFormField>
                </div>
            </div>
        </div>

        @* ═══════════════════════════════════════════════ *@
        @* ═══       ORGANISMS                        ═══ *@
        @* ═══════════════════════════════════════════════ *@

        <div class="pt-8">
            <GzSeparator />
            <p class="mt-6 text-xs font-medium uppercase tracking-widest text-primary">Organisms</p>
        </div>

        @* ─── Dialog ──────────────────────────────────── *@
        <div id="dialog">
            <div class="mb-6">
                <h2 class="text-xl font-semibold tracking-tight text-foreground">Dialog</h2>
                <p class="mt-1 text-sm text-muted-foreground">Modal with backdrop blur, click-outside-to-close, X button, Header/Footer slots, 4 sizes, and accessible ARIA.</p>
            </div>

            <div class="rounded-xl border border-border/50 bg-card p-6 shadow-xs sm:p-8">
                <div class="flex flex-wrap gap-3">
                    <GzButton @onclick="() => _dialogOpen = true">Open Dialog</GzButton>
                    <GzButton Variant="ButtonVariant.Outline" @onclick="() => _dialogSmOpen = true">Small Dialog</GzButton>
                </div>
            </div>

            <GzDialog @bind-Open="_dialogOpen" Title="Edit Profile" Description="Make changes to your profile here. Click save when you're done.">
                <ChildContent>
                    <div class="space-y-4">
                        <GzFormField Label="Name" Id="dlg-name">
                            <GzInput Id="dlg-name" Placeholder="John Doe" />
                        </GzFormField>
                        <GzFormField Label="Email" Id="dlg-email">
                            <GzInput Id="dlg-email" Type="email" Placeholder="john@example.com" />
                        </GzFormField>
                    </div>
                </ChildContent>
                <Footer>
                    <GzButton Variant="ButtonVariant.Ghost" @onclick="() => _dialogOpen = false">Cancel</GzButton>
                    <GzButton @onclick="() => _dialogOpen = false">Save Changes</GzButton>
                </Footer>
            </GzDialog>

            <GzDialog @bind-Open="_dialogSmOpen" Title="Confirm Action" Description="Are you sure you want to continue?" Size="DialogSize.Sm">
                <Footer>
                    <GzButton Variant="ButtonVariant.Ghost" @onclick="() => _dialogSmOpen = false">Cancel</GzButton>
                    <GzButton Variant="ButtonVariant.Destructive" @onclick="() => _dialogSmOpen = false">Delete</GzButton>
                </Footer>
            </GzDialog>
        </div>

        @* ─── DropdownMenu ────────────────────────────── *@
        <div id="dropdown">
            <div class="mb-6">
                <h2 class="text-xl font-semibold tracking-tight text-foreground">DropdownMenu</h2>
                <p class="mt-1 text-sm text-muted-foreground">Trigger + floating menu with items, separators, keyboard shortcut labels, and disabled state.</p>
            </div>

            <div class="rounded-xl border border-border/50 bg-card p-6 shadow-xs sm:p-8">
                <GzDropdownMenu>
                    <Trigger>
                        <GzButton Variant="ButtonVariant.Outline">
                            <ChildContent>Open Menu</ChildContent>
                        </GzButton>
                    </Trigger>
                    <ChildContent>
                        <GzDropdownMenuItem Shortcut="⌘N">New File</GzDropdownMenuItem>
                        <GzDropdownMenuItem Shortcut="⌘O">Open</GzDropdownMenuItem>
                        <GzSeparator class="my-1" />
                        <GzDropdownMenuItem Shortcut="⌘S">Save</GzDropdownMenuItem>
                        <GzDropdownMenuItem Shortcut="⇧⌘S">Save As</GzDropdownMenuItem>
                        <GzSeparator class="my-1" />
                        <GzDropdownMenuItem Disabled="true">Print</GzDropdownMenuItem>
                    </ChildContent>
                </GzDropdownMenu>
            </div>
        </div>

        @* ─── Popover ─────────────────────────────────── *@
        <div id="popover">
            <div class="mb-6">
                <h2 class="text-xl font-semibold tracking-tight text-foreground">Popover</h2>
                <p class="mt-1 text-sm text-muted-foreground">Click-triggered floating panel. General-purpose — any content can go inside.</p>
            </div>

            <div class="rounded-xl border border-border/50 bg-card p-6 shadow-xs sm:p-8">
                <GzPopover Align="start">
                    <Trigger>
                        <GzButton Variant="ButtonVariant.Outline">Open Popover</GzButton>
                    </Trigger>
                    <ChildContent>
                        <div class="space-y-4">
                            <div>
                                <h4 class="text-sm font-semibold text-foreground">Dimensions</h4>
                                <p class="text-xs text-muted-foreground">Set the dimensions for the layer.</p>
                            </div>
                            <div class="grid grid-cols-2 gap-3">
                                <GzFormField Label="Width" Id="pop-w">
                                    <GzInput Id="pop-w" Placeholder="100%" />
                                </GzFormField>
                                <GzFormField Label="Height" Id="pop-h">
                                    <GzInput Id="pop-h" Placeholder="auto" />
                                </GzFormField>
                            </div>
                        </div>
                    </ChildContent>
                </GzPopover>
            </div>
        </div>

        </div> @* end flex-1 *@
    </div>
</section>

@code {
    private bool _acceptTerms;
    private bool _newsletter = true;
    private bool _notifications = true;
    private bool _analytics;
    private string _selectedPlan = "pro";
    private string? _activeTab;
    private bool _dialogOpen;
    private bool _dialogSmOpen;
    private string? _selectedFramework;

    private List<TabItem> _demoPanels = new();

    private readonly List<SelectOption> _frameworkOptions = new()
    {
        new() { Value = "blazor", Label = "Blazor" },
        new() { Value = "react", Label = "React" },
        new() { Value = "vue", Label = "Vue" },
        new() { Value = "angular", Label = "Angular" },
        new() { Value = "svelte", Label = "Svelte", Disabled = true }
    };

    protected override void OnInitialized()
    {
        _demoPanels = new List<TabItem>
        {
            new TabItem
            {
                Key = "account",
                Label = "Account",
                Content = @<div class="space-y-4">
                    <GzFormField Label="Name" Id="tab-name" Description="Your full name as shown on your profile.">
                        <GzInput Id="tab-name" Placeholder="John Doe" />
                    </GzFormField>
                    <GzFormField Label="Email" Id="tab-email">
                        <GzInput Id="tab-email" Type="email" Placeholder="john@example.com" />
                    </GzFormField>
                    <GzButton Size="ButtonSize.Sm">Save Changes</GzButton>
                </div>
            },
            new TabItem
            {
                Key = "password",
                Label = "Password",
                Content = @<div class="space-y-4">
                    <GzFormField Label="Current Password" Id="tab-current-pw">
                        <GzInput Id="tab-current-pw" Type="password" Placeholder="Enter current password" />
                    </GzFormField>
                    <GzFormField Label="New Password" Id="tab-new-pw">
                        <GzInput Id="tab-new-pw" Type="password" Placeholder="Enter new password" />
                    </GzFormField>
                    <GzButton Size="ButtonSize.Sm">Update Password</GzButton>
                </div>
            },
            new TabItem
            {
                Key = "notifications",
                Label = "Notifications",
                Content = @<div class="space-y-4">
                    <GzSwitch @bind-Checked="_notifications">Email notifications</GzSwitch>
                    <GzSwitch @bind-Checked="_analytics">Marketing emails</GzSwitch>
                    <GzSwitch Checked="true" Disabled="true">Security alerts (always on)</GzSwitch>
                </div>
            }
        };
    }

    private void SelectPlan(string plan)
    {
        _selectedPlan = plan;
    }
}
