@page "/docs/accessibility"

<PageTitle>Accessibility — GlazeUI</PageTitle>
<HeadContent>
    <meta name="description" content="WCAG 2.1 AA accessibility matrix for all 23 GlazeUI components — keyboard support, ARIA roles, screen reader labels, and focus management." />
</HeadContent>

<div class="mx-auto flex max-w-6xl gap-10 px-4 py-12 sm:px-6 lg:px-8">

    @* ─── Sidebar ──────────────────────────────── *@
    <aside class="hidden w-56 shrink-0 lg:block">
        <nav class="sticky top-24 space-y-1">
            <p class="mb-3 text-xs font-medium uppercase tracking-widest text-muted-foreground">Accessibility</p>
            <a href="/docs/accessibility#overview" data-enhance-nav="false" class="block rounded-md px-3 py-1.5 text-sm text-muted-foreground transition-colors hover:text-foreground">Overview</a>
            <a href="/docs/accessibility#keyboard" data-enhance-nav="false" class="block rounded-md px-3 py-1.5 text-sm text-muted-foreground transition-colors hover:text-foreground">Keyboard Matrix</a>
            <a href="/docs/accessibility#aria" data-enhance-nav="false" class="block rounded-md px-3 py-1.5 text-sm text-muted-foreground transition-colors hover:text-foreground">ARIA Roles</a>
            <a href="/docs/accessibility#focus" data-enhance-nav="false" class="block rounded-md px-3 py-1.5 text-sm text-muted-foreground transition-colors hover:text-foreground">Focus Management</a>
            <a href="/docs/accessibility#color" data-enhance-nav="false" class="block rounded-md px-3 py-1.5 text-sm text-muted-foreground transition-colors hover:text-foreground">Color & Contrast</a>
            <a href="/docs/accessibility#rtl" data-enhance-nav="false" class="block rounded-md px-3 py-1.5 text-sm text-muted-foreground transition-colors hover:text-foreground">RTL Support</a>
        </nav>
    </aside>

    @* ─── Content ──────────────────────────────── *@
    <div class="min-w-0 flex-1">
        <p class="text-sm font-medium text-primary">Documentation</p>
        <h1 class="mt-2 text-3xl font-bold tracking-tight text-foreground sm:text-4xl">
            Accessibility
        </h1>
        <p class="mt-3 max-w-2xl text-lg text-muted-foreground">
            WCAG 2.1 AA compliance matrix for every GlazeUI component — keyboard interactions, ARIA semantics, focus rings, and RTL support.
        </p>

        @* ─── Overview ───────────────────────── *@
        <section id="overview" class="mt-12 scroll-mt-24">
            <h2 class="text-xl font-semibold tracking-tight text-foreground">Overview</h2>
            <GzSeparator class="mt-3 mb-6" />

            <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
                <GzCard>
                    <ChildContent>
                        <p class="text-2xl font-bold text-foreground">23</p>
                        <p class="text-sm text-muted-foreground">Components audited</p>
                    </ChildContent>
                </GzCard>
                <GzCard>
                    <ChildContent>
                        <p class="text-2xl font-bold text-foreground">AA</p>
                        <p class="text-sm text-muted-foreground">WCAG 2.1 target</p>
                    </ChildContent>
                </GzCard>
                <GzCard>
                    <ChildContent>
                        <p class="text-2xl font-bold text-foreground">0</p>
                        <p class="text-sm text-muted-foreground">Raw color classes</p>
                    </ChildContent>
                </GzCard>
                <GzCard>
                    <ChildContent>
                        <p class="text-2xl font-bold text-foreground">100%</p>
                        <p class="text-sm text-muted-foreground">RTL logical properties</p>
                    </ChildContent>
                </GzCard>
            </div>
        </section>

        @* ─── Keyboard Matrix ────────────────── *@
        <section id="keyboard" class="mt-16 scroll-mt-24">
            <h2 class="text-xl font-semibold tracking-tight text-foreground">Keyboard Matrix</h2>
            <GzSeparator class="mt-3 mb-6" />

            <div class="overflow-x-auto rounded-lg border border-border/50">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-border/50 bg-muted/50">
                            <th class="px-4 py-2.5 text-start font-medium text-foreground">Component</th>
                            <th class="px-4 py-2.5 text-start font-medium text-foreground">Tab</th>
                            <th class="px-4 py-2.5 text-start font-medium text-foreground">Enter/Space</th>
                            <th class="px-4 py-2.5 text-start font-medium text-foreground">Escape</th>
                            <th class="px-4 py-2.5 text-start font-medium text-foreground">Arrows</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in _keyboardMatrix)
                        {
                            <tr class="border-b border-border/30 last:border-0">
                                <td class="px-4 py-2 font-medium text-foreground">@row.Component</td>
                                <td class="px-4 py-2 text-muted-foreground">@row.Tab</td>
                                <td class="px-4 py-2 text-muted-foreground">@row.Enter</td>
                                <td class="px-4 py-2 text-muted-foreground">@row.Escape</td>
                                <td class="px-4 py-2 text-muted-foreground">@row.Arrows</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>

        @* ─── ARIA Roles ─────────────────────── *@
        <section id="aria" class="mt-16 scroll-mt-24">
            <h2 class="text-xl font-semibold tracking-tight text-foreground">ARIA Roles & Attributes</h2>
            <GzSeparator class="mt-3 mb-6" />

            <div class="overflow-x-auto rounded-lg border border-border/50">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-border/50 bg-muted/50">
                            <th class="px-4 py-2.5 text-start font-medium text-foreground">Component</th>
                            <th class="px-4 py-2.5 text-start font-medium text-foreground">Role</th>
                            <th class="px-4 py-2.5 text-start font-medium text-foreground">Key Attributes</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in _ariaMatrix)
                        {
                            <tr class="border-b border-border/30 last:border-0">
                                <td class="px-4 py-2 font-medium text-foreground">@row.Component</td>
                                <td class="px-4 py-2"><code class="rounded bg-muted px-1.5 py-0.5 font-mono text-xs text-foreground">@row.Role</code></td>
                                <td class="px-4 py-2 text-muted-foreground">@row.Attributes</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>

        @* ─── Focus Management ───────────────── *@
        <section id="focus" class="mt-16 scroll-mt-24">
            <h2 class="text-xl font-semibold tracking-tight text-foreground">Focus Management</h2>
            <GzSeparator class="mt-3 mb-6" />

            <GzCard>
                <ChildContent>
                    <div class="space-y-3 text-sm">
                        <div class="flex items-start gap-3">
                            <GzBadge Variant="BadgeVariant.Secondary" class="shrink-0 mt-0.5">Ring</GzBadge>
                            <div>
                                <p class="font-medium text-foreground">focus-visible:ring-2 pattern</p>
                                <p class="text-muted-foreground">All interactive elements use <code class="rounded bg-muted px-1 py-0.5 font-mono text-xs">focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 ring-offset-background</code>. Rings only appear on keyboard navigation, not mouse clicks.</p>
                            </div>
                        </div>
                        <GzSeparator />
                        <div class="flex items-start gap-3">
                            <GzBadge Variant="BadgeVariant.Secondary" class="shrink-0 mt-0.5">Order</GzBadge>
                            <div>
                                <p class="font-medium text-foreground">Natural tab order</p>
                                <p class="text-muted-foreground">No custom <code class="rounded bg-muted px-1 py-0.5 font-mono text-xs">tabindex</code> values. Components follow the DOM order. Interactive elements are reachable via Tab key in sequence.</p>
                            </div>
                        </div>
                        <GzSeparator />
                        <div class="flex items-start gap-3">
                            <GzBadge Variant="BadgeVariant.Secondary" class="shrink-0 mt-0.5">Trap</GzBadge>
                            <div>
                                <p class="font-medium text-foreground">Dialog focus behavior</p>
                                <p class="text-muted-foreground">GzDialog blocks background interaction via fixed overlay. Escape key closes the dialog.</p>
                            </div>
                        </div>
                        <GzSeparator />
                        <div class="flex items-start gap-3">
                            <GzBadge Variant="BadgeVariant.Secondary" class="shrink-0 mt-0.5">Disabled</GzBadge>
                            <div>
                                <p class="font-medium text-foreground">Disabled state</p>
                                <p class="text-muted-foreground">All interactive components use <code class="rounded bg-muted px-1 py-0.5 font-mono text-xs">disabled:pointer-events-none disabled:opacity-50</code>. Disabled elements are not focusable.</p>
                            </div>
                        </div>
                    </div>
                </ChildContent>
            </GzCard>
        </section>

        @* ─── Color & Contrast ───────────────── *@
        <section id="color" class="mt-16 scroll-mt-24">
            <h2 class="text-xl font-semibold tracking-tight text-foreground">Color & Contrast</h2>
            <GzSeparator class="mt-3 mb-6" />

            <GzCard>
                <ChildContent>
                    <div class="space-y-3 text-sm">
                        <div class="flex items-start gap-3">
                            <GzBadge Variant="BadgeVariant.Secondary" class="shrink-0 mt-0.5">Tokens</GzBadge>
                            <p class="text-muted-foreground">All colors are defined via <code class="rounded bg-muted px-1 py-0.5 font-mono text-xs">oklch()</code> tokens. Contrast ratios are controlled at the token level — components inherit automatically.</p>
                        </div>
                        <GzSeparator />
                        <div class="flex items-start gap-3">
                            <GzBadge Variant="BadgeVariant.Secondary" class="shrink-0 mt-0.5">Not Color Alone</GzBadge>
                            <p class="text-muted-foreground">Alerts use icons + color. Error states use ring color + error text. Status badges use shape + color. Information is never conveyed by color alone.</p>
                        </div>
                        <GzSeparator />
                        <div class="flex items-start gap-3">
                            <GzBadge Variant="BadgeVariant.Secondary" class="shrink-0 mt-0.5">Dark Mode</GzBadge>
                            <p class="text-muted-foreground">Token values are tuned separately for light and dark mode to maintain readability. Both themes target WCAG AA contrast ratios (4.5:1 for text, 3:1 for large text).</p>
                        </div>
                    </div>
                </ChildContent>
            </GzCard>
        </section>

        @* ─── RTL Support ────────────────────── *@
        <section id="rtl" class="mt-16 scroll-mt-24 mb-8">
            <h2 class="text-xl font-semibold tracking-tight text-foreground">RTL Support</h2>
            <GzSeparator class="mt-3 mb-6" />

            <div class="space-y-6">
                <GzCard>
                    <Header><h3 class="font-semibold text-foreground">Enabling RTL</h3></Header>
                    <ChildContent>
                        <div class="space-y-4 text-sm">
                            <p class="text-muted-foreground">Add <code class="rounded bg-muted px-1.5 py-0.5 font-mono text-xs">dir="rtl"</code> to your <code class="rounded bg-muted px-1.5 py-0.5 font-mono text-xs">&lt;html&gt;</code> element. All components use CSS logical properties and will automatically mirror.</p>
                            <div class="overflow-hidden rounded-lg border border-border/50 bg-muted">
                                <pre class="overflow-x-auto p-4 font-mono text-sm text-foreground"><code>&lt;html dir="rtl" lang="ar"&gt;</code></pre>
                            </div>
                        </div>
                    </ChildContent>
                </GzCard>

                <GzCard>
                    <Header><h3 class="font-semibold text-foreground">Logical Property Mapping</h3></Header>
                    <ChildContent>
                        <div class="overflow-x-auto">
                            <table class="w-full text-sm">
                                <thead>
                                    <tr class="border-b border-border/50">
                                        <th class="px-4 py-2 text-start font-medium text-foreground">Physical (banned)</th>
                                        <th class="px-4 py-2 text-start font-medium text-foreground">Logical (required)</th>
                                        <th class="px-4 py-2 text-start font-medium text-foreground">CSS Property</th>
                                    </tr>
                                </thead>
                                <tbody class="text-muted-foreground">
                                    <tr class="border-b border-border/30"><td class="px-4 py-2 line-through">ml-*</td><td class="px-4 py-2 font-medium text-foreground">ms-*</td><td class="px-4 py-2">margin-inline-start</td></tr>
                                    <tr class="border-b border-border/30"><td class="px-4 py-2 line-through">mr-*</td><td class="px-4 py-2 font-medium text-foreground">me-*</td><td class="px-4 py-2">margin-inline-end</td></tr>
                                    <tr class="border-b border-border/30"><td class="px-4 py-2 line-through">pl-*</td><td class="px-4 py-2 font-medium text-foreground">ps-*</td><td class="px-4 py-2">padding-inline-start</td></tr>
                                    <tr class="border-b border-border/30"><td class="px-4 py-2 line-through">pr-*</td><td class="px-4 py-2 font-medium text-foreground">pe-*</td><td class="px-4 py-2">padding-inline-end</td></tr>
                                    <tr class="border-b border-border/30"><td class="px-4 py-2 line-through">left-*</td><td class="px-4 py-2 font-medium text-foreground">start-*</td><td class="px-4 py-2">inset-inline-start</td></tr>
                                    <tr class="border-b border-border/30"><td class="px-4 py-2 line-through">right-*</td><td class="px-4 py-2 font-medium text-foreground">end-*</td><td class="px-4 py-2">inset-inline-end</td></tr>
                                    <tr class="border-b border-border/30"><td class="px-4 py-2 line-through">text-left</td><td class="px-4 py-2 font-medium text-foreground">text-start</td><td class="px-4 py-2">text-align: start</td></tr>
                                    <tr><td class="px-4 py-2 line-through">text-right</td><td class="px-4 py-2 font-medium text-foreground">text-end</td><td class="px-4 py-2">text-align: end</td></tr>
                                </tbody>
                            </table>
                        </div>
                    </ChildContent>
                </GzCard>
            </div>
        </section>
    </div>
</div>

@code {
    private record KeyboardRow(string Component, string Tab, string Enter, string Escape, string Arrows);
    private record AriaRow(string Component, string Role, string Attributes);

    private readonly KeyboardRow[] _keyboardMatrix = new[]
    {
        new KeyboardRow("GzButton", "Focusable", "Activates click", "—", "—"),
        new KeyboardRow("GzInput", "Focusable", "—", "—", "—"),
        new KeyboardRow("GzTextarea", "Focusable", "New line", "—", "—"),
        new KeyboardRow("GzCheckbox", "Focusable", "Toggles checked", "—", "—"),
        new KeyboardRow("GzRadio", "Focusable", "Selects option", "—", "Cycles options"),
        new KeyboardRow("GzSwitch", "Focusable", "Toggles on/off", "—", "—"),
        new KeyboardRow("GzSelect", "Focusable", "Opens/selects", "Closes dropdown", "Navigate options"),
        new KeyboardRow("GzTabs", "Focuses active tab", "Activates tab", "—", "Navigate tabs"),
        new KeyboardRow("GzTooltip", "Shows on focus-within", "—", "—", "—"),
        new KeyboardRow("GzDialog", "—", "—", "Closes dialog", "—"),
        new KeyboardRow("GzDropdownMenu", "Focusable trigger", "Opens menu", "Closes menu", "Navigate items"),
        new KeyboardRow("GzPopover", "Focusable trigger", "Toggles panel", "—", "—"),
    };

    private readonly AriaRow[] _ariaMatrix = new[]
    {
        new AriaRow("GzButton", "button", "aria-busy (loading), aria-disabled"),
        new AriaRow("GzInput", "textbox", "aria-invalid, aria-describedby (error)"),
        new AriaRow("GzTextarea", "textbox", "aria-invalid, aria-describedby (error)"),
        new AriaRow("GzCheckbox", "checkbox", "aria-checked"),
        new AriaRow("GzSwitch", "switch", "aria-checked"),
        new AriaRow("GzSelect", "combobox", "aria-expanded, aria-haspopup=listbox"),
        new AriaRow("GzTabs", "tablist", "role=tab, role=tabpanel, aria-selected"),
        new AriaRow("GzAlert", "alert", "aria-live=polite (auto)"),
        new AriaRow("GzProgress", "progressbar", "aria-valuenow, aria-valuemin, aria-valuemax"),
        new AriaRow("GzDialog", "dialog", "aria-modal=true"),
        new AriaRow("GzDropdownMenu", "menu", "role=menuitem on children"),
        new AriaRow("GzTooltip", "tooltip", "CSS-only visibility (group-hover/focus-within)"),
    };
}
