@page "/"

<PageTitle>GlazeUI — Premium Design System for Blazor + Tailwind CSS v4</PageTitle>
<HeadContent>
    <meta name="description" content="GlazeUI is a premium, headless-inspired design system for Blazor Web Apps powered by Tailwind CSS v4. Own the code. Ship with confidence." />
</HeadContent>

@* === Hero Section === *@
<section class="relative overflow-hidden">
    @* Subtle radial glow — uses CSS variable, not raw color *@
    <div class="absolute inset-0 -z-10 bg-[radial-gradient(ellipse_at_top,oklch(0.95_0.03_250),transparent_60%)] dark:bg-[radial-gradient(ellipse_at_top,oklch(0.18_0.04_250),transparent_60%)]"></div>

    <div class="mx-auto max-w-7xl px-4 py-24 sm:px-6 sm:py-32 lg:px-8 lg:py-40">
        <div class="mx-auto max-w-3xl text-center">
            @* Status badge *@
            <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-border/50 bg-surface px-4 py-1.5 text-xs font-medium text-muted-foreground shadow-xs">
                <span class="relative flex size-2">
                    <span class="absolute inline-flex size-full animate-ping rounded-full bg-primary/60 opacity-75"></span>
                    <span class="relative inline-flex size-2 rounded-full bg-primary"></span>
                </span>
                Phase 0 — Foundation
            </div>

            @* Heading — no gradient text, clean typography hierarchy *@
            <h1 class="text-4xl font-bold tracking-tight text-foreground sm:text-5xl lg:text-6xl">
                The design system for
                <br class="hidden sm:block" />
                <span class="text-primary">Blazor + Tailwind</span>
            </h1>

            @* Subheading *@
            <p class="mt-6 text-lg leading-relaxed text-muted-foreground sm:text-xl">
                Beautifully designed. Fully accessible. You own the code.
                <br class="hidden sm:block" />
                Production-grade components with design tokens, UX guidelines, and pixel-perfect Figma resources.
            </p>

            @* CTA Buttons — using GzButton components *@
            <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
                <GzButton Size="ComponentSize.Lg" OnClick="@(() => NavigateToComponents())">
                    <Icon>
                        <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M21 7.5l-2.25-1.313M21 7.5v2.25m0-2.25l-2.25 1.313M3 7.5l2.25-1.313M3 7.5l2.25 1.313M3 7.5v2.25m9 3l2.25-1.313M12 12.75l-2.25-1.313M12 12.75V15m0 6.75l2.25-1.313M12 21.75V19.5m0 2.25l-2.25-1.313m0-16.875L12 2.25l2.25 1.313M21 14.25v2.25l-2.25 1.313m-13.5 0L3 16.5v-2.25" />
                        </svg>
                    </Icon>
                    <ChildContent>Browse Components</ChildContent>
                </GzButton>
                <GzButton Variant="ComponentVariant.Outline" Size="ComponentSize.Lg">
                    <Icon>
                        <svg class="size-4" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
                        </svg>
                    </Icon>
                    <ChildContent>Star on GitHub</ChildContent>
                </GzButton>
            </div>
        </div>
    </div>
</section>

@* === Value Propositions === *@
<section class="border-t border-border/50 py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-2xl lg:max-w-none">
            <div class="mb-16 max-w-2xl">
                <h2 class="text-2xl font-bold tracking-tight text-foreground sm:text-3xl">
                    Not a component library. A design system.
                </h2>
                <p class="mt-4 text-muted-foreground">
                    GlazeUI goes beyond pre-built components to deliver a complete design philosophy for Blazor applications.
                </p>
            </div>

            <div class="grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-border/50 bg-border/50 sm:grid-cols-2 lg:grid-cols-3">
                @* Feature cells — no icon circles, just clean text *@
                <div class="bg-card p-8">
                    <h3 class="text-base font-semibold text-foreground">Own the Code</h3>
                    <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
                        Copy component source directly into your project. Modify everything — markup, logic, styling. No hidden dependencies.
                    </p>
                </div>

                <div class="bg-card p-8">
                    <h3 class="text-base font-semibold text-foreground">Design Tokens</h3>
                    <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
                        A unified token pipeline via Tailwind v4's <code class="rounded bg-muted px-1.5 py-0.5 font-mono text-xs">@@theme</code>. Code and Figma always in sync.
                    </p>
                </div>

                <div class="bg-card p-8">
                    <h3 class="text-base font-semibold text-foreground">UX Guidelines</h3>
                    <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
                        Research-backed guidance on <em>when</em> and <em>why</em> to use each component. Cognitive load analysis and pattern recipes.
                    </p>
                </div>

                <div class="bg-card p-8">
                    <h3 class="text-base font-semibold text-foreground">Accessible</h3>
                    <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
                        WCAG 2.1 AA compliant. Every component ships with keyboard interactions, ARIA specs, and screen reader documentation.
                    </p>
                </div>

                <div class="bg-card p-8">
                    <h3 class="text-base font-semibold text-foreground">Pixel-Perfect Figma</h3>
                    <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
                        Every component has a matching Figma counterpart with shared token variables. Design and code stay perfectly in sync.
                    </p>
                </div>

                <div class="bg-card p-8">
                    <h3 class="text-base font-semibold text-foreground">CLI Distribution</h3>
                    <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
                        Install components with a single command. The CLI fetches source code, adjusts namespaces, and resolves dependencies.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

@* === Code Preview === *@
<section class="border-t border-border/50 bg-surface py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-3xl">
            <div class="mb-10 max-w-2xl">
                <h2 class="text-2xl font-bold tracking-tight text-foreground sm:text-3xl">
                    Ship faster with premium atoms
                </h2>
                <p class="mt-4 text-muted-foreground">
                    Every component supports 6 variants, loading states, icon slots, and accessible focus rings out of the box.
                </p>
            </div>

            @* Live component preview *@
            <div class="rounded-2xl border border-border/50 bg-card shadow-sm">
                <div class="border-b border-border/50 px-6 py-4">
                    <div class="flex items-center gap-2">
                        <div class="size-3 rounded-full bg-border/80"></div>
                        <div class="size-3 rounded-full bg-border/80"></div>
                        <div class="size-3 rounded-full bg-border/80"></div>
                        <span class="ms-3 text-xs text-muted-foreground">GzButton Preview</span>
                    </div>
                </div>
                <div class="p-8">
                    <div class="flex flex-wrap items-center gap-4">
                        <GzButton>Default</GzButton>
                        <GzButton Variant="ComponentVariant.Secondary">Secondary</GzButton>
                        <GzButton Variant="ComponentVariant.Destructive">Destructive</GzButton>
                        <GzButton Variant="ComponentVariant.Outline">Outline</GzButton>
                        <GzButton Variant="ComponentVariant.Ghost">Ghost</GzButton>
                        <GzButton Loading="true">Loading</GzButton>
                    </div>
                </div>
            </div>

            @* Call to action *@
            <div class="mt-8 text-center">
                <GzButton Variant="ComponentVariant.Ghost" OnClick="@(() => NavigateToComponents())">
                    View all components →
                </GzButton>
            </div>
        </div>
    </div>
</section>

@* === Tech Stack === *@
<section class="border-t border-border/50 py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-2xl text-center">
            <p class="text-sm font-medium uppercase tracking-widest text-muted-foreground">Built with</p>
            <div class="mt-6 flex flex-wrap items-center justify-center gap-8 text-muted-foreground">
                <span class="text-2xl font-bold text-foreground">.NET 9</span>
                <GzSeparator Orientation="SeparatorOrientation.Vertical" class="h-6" />
                <span class="text-2xl font-bold text-foreground">Blazor</span>
                <GzSeparator Orientation="SeparatorOrientation.Vertical" class="h-6" />
                <span class="text-2xl font-bold text-foreground">Tailwind v4</span>
            </div>
        </div>
    </div>
</section>

@inject NavigationManager Navigation

@code {
    private void NavigateToComponents()
    {
        Navigation.NavigateTo("/components");
    }
}
