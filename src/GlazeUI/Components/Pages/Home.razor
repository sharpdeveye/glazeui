@page "/"

<PageTitle>GlazeUI — Design System for Blazor + TailwindCSS</PageTitle>

@* === Hero Section === *@
<section class="relative overflow-hidden">
    @* Gradient background *@
    <div class="absolute inset-0 -z-10 bg-[radial-gradient(ellipse_at_top,var(--color-primary-100),transparent_60%)] dark:bg-[radial-gradient(ellipse_at_top,oklch(0.25_0.08_250),transparent_60%)]"></div>

    <div class="mx-auto max-w-7xl px-4 py-24 sm:px-6 sm:py-32 lg:px-8 lg:py-40">
        <div class="mx-auto max-w-3xl text-center">
            @* Badge *@
            <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-border bg-surface px-4 py-1.5 text-xs font-medium text-muted-foreground shadow-xs">
                <span class="relative flex h-2 w-2">
                    <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-primary-400 opacity-75"></span>
                    <span class="relative inline-flex h-2 w-2 rounded-full bg-primary-500"></span>
                </span>
                Phase 0 — Foundation
            </div>

            @* Heading *@
            <h1 class="text-4xl font-bold tracking-tight text-foreground sm:text-5xl lg:text-6xl">
                The design system for
                <span class="bg-gradient-to-r from-primary-400 to-primary-600 bg-clip-text text-transparent">
                    Blazor + Tailwind
                </span>
            </h1>

            @* Subheading *@
            <p class="mt-6 text-lg leading-relaxed text-muted-foreground sm:text-xl">
                Beautifully designed. Fully accessible. You own the code.
                <br class="hidden sm:block" />
                Production-grade components with UX guidelines, design tokens, and pixel-perfect Figma resources.
            </p>

            @* CTA Buttons *@
            <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
                <a href="https://github.com/sharpdeveye/glazeui"
                   target="_blank"
                   rel="noopener"
                   class="inline-flex h-12 items-center justify-center gap-2 rounded-lg bg-primary-500 px-6 text-sm font-semibold text-white shadow-md transition-all duration-200 hover:bg-primary-600 hover:shadow-lg focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-500">
                    <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
                    Star on GitHub
                </a>
                <a href="#features"
                   class="inline-flex h-12 items-center justify-center gap-2 rounded-lg border border-border bg-surface px-6 text-sm font-semibold text-foreground shadow-sm transition-all duration-200 hover:bg-muted focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ring">
                    Learn More ↓
                </a>
            </div>
        </div>
    </div>
</section>

@* === Features Section === *@
<section id="features" class="border-t border-border bg-surface py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-2xl text-center">
            <h2 class="text-2xl font-bold tracking-tight text-foreground sm:text-3xl">
                Not a component library. A design system.
            </h2>
            <p class="mt-4 text-muted-foreground">
                GlazeUI goes beyond pre-built components to deliver a complete design philosophy.
            </p>
        </div>

        <div class="mx-auto mt-16 grid max-w-5xl grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
            @* Feature Card 1 *@
            <div class="group rounded-xl border border-border bg-card p-6 shadow-sm transition-all duration-300 hover:border-primary-300 hover:shadow-md dark:hover:border-primary-700">
                <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-primary-100 text-primary-600 dark:bg-primary-950 dark:text-primary-400">
                    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" />
                    </svg>
                </div>
                <h3 class="text-base font-semibold text-foreground">Own the Code</h3>
                <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
                    Copy component source directly into your project. Modify everything — markup, logic, styling. No hidden dependencies.
                </p>
            </div>

            @* Feature Card 2 *@
            <div class="group rounded-xl border border-border bg-card p-6 shadow-sm transition-all duration-300 hover:border-primary-300 hover:shadow-md dark:hover:border-primary-700">
                <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-primary-100 text-primary-600 dark:bg-primary-950 dark:text-primary-400">
                    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.764m3.42 3.42a6.776 6.776 0 00-3.42-3.42" />
                    </svg>
                </div>
                <h3 class="text-base font-semibold text-foreground">Design Tokens</h3>
                <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
                    A unified token pipeline via Tailwind v4's <code class="rounded bg-muted px-1.5 py-0.5 font-mono text-xs">@@theme</code>. Code and Figma always in sync.
                </p>
            </div>

            @* Feature Card 3 *@
            <div class="group rounded-xl border border-border bg-card p-6 shadow-sm transition-all duration-300 hover:border-primary-300 hover:shadow-md dark:hover:border-primary-700">
                <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-primary-100 text-primary-600 dark:bg-primary-950 dark:text-primary-400">
                    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
                    </svg>
                </div>
                <h3 class="text-base font-semibold text-foreground">UX Guidelines</h3>
                <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
                    Research-backed guidance on <em>when</em> and <em>why</em> to use each component. Cognitive load analysis, writing conventions, pattern recipes.
                </p>
            </div>

            @* Feature Card 4 *@
            <div class="group rounded-xl border border-border bg-card p-6 shadow-sm transition-all duration-300 hover:border-primary-300 hover:shadow-md dark:hover:border-primary-700">
                <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-primary-100 text-primary-600 dark:bg-primary-950 dark:text-primary-400">
                    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 006 3.75v16.5a2.25 2.25 0 002.25 2.25h7.5A2.25 2.25 0 0018 20.25V3.75a2.25 2.25 0 00-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3" />
                    </svg>
                </div>
                <h3 class="text-base font-semibold text-foreground">Accessible</h3>
                <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
                    WCAG 2.1 AA compliant. Every component ships with keyboard interaction tables, ARIA specs, and screen reader behavior documentation.
                </p>
            </div>

            @* Feature Card 5 *@
            <div class="group rounded-xl border border-border bg-card p-6 shadow-sm transition-all duration-300 hover:border-primary-300 hover:shadow-md dark:hover:border-primary-700">
                <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-primary-100 text-primary-600 dark:bg-primary-950 dark:text-primary-400">
                    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4.098 19.902a3.75 3.75 0 005.304 0l6.401-6.402M6.75 21A3.75 3.75 0 013 17.25V4.125C3 3.504 3.504 3 4.125 3h5.25c.621 0 1.125.504 1.125 1.125v4.072M6.75 21a3.75 3.75 0 003.75-3.75V8.197M6.75 21h13.125c.621 0 1.125-.504 1.125-1.125v-5.25c0-.621-.504-1.125-1.125-1.125h-4.072M10.5 8.197l2.88-2.88c.438-.439 1.15-.439 1.59 0l3.712 3.713c.44.44.44 1.152 0 1.59l-2.879 2.88M6.75 17.25h.008v.008H6.75v-.008z" />
                    </svg>
                </div>
                <h3 class="text-base font-semibold text-foreground">Pixel-Perfect Figma</h3>
                <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
                    Every component has a matching Figma counterpart with shared token variables. Design and code are always in perfect sync.
                </p>
            </div>

            @* Feature Card 6 *@
            <div class="group rounded-xl border border-border bg-card p-6 shadow-sm transition-all duration-300 hover:border-primary-300 hover:shadow-md dark:hover:border-primary-700">
                <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-primary-100 text-primary-600 dark:bg-primary-950 dark:text-primary-400">
                    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 7.5l3 2.25-3 2.25m4.5 0h3m-9 8.25h13.5A2.25 2.25 0 0021 18V6a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 6v12a2.25 2.25 0 002.25 2.25z" />
                    </svg>
                </div>
                <h3 class="text-base font-semibold text-foreground">CLI Distribution</h3>
                <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
                    Install components with a single command. The CLI fetches source code, adjusts namespaces, and resolves dependencies automatically.
                </p>
            </div>
        </div>
    </div>
</section>

@* === Tech Stack Section === *@
<section class="border-t border-border py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-2xl text-center">
            <p class="text-sm font-medium uppercase tracking-widest text-muted-foreground">Built with</p>
            <div class="mt-6 flex flex-wrap items-center justify-center gap-8 text-muted-foreground">
                <div class="flex items-center gap-2">
                    <span class="text-2xl font-bold text-foreground">.NET 9</span>
                </div>
                <span class="text-border">|</span>
                <div class="flex items-center gap-2">
                    <span class="text-2xl font-bold text-foreground">Blazor</span>
                </div>
                <span class="text-border">|</span>
                <div class="flex items-center gap-2">
                    <span class="text-2xl font-bold text-foreground">Tailwind v4</span>
                </div>
            </div>
        </div>
    </div>
</section>
