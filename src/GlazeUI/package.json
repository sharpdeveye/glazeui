{
  "name": "glazeui",
  "version": "0.0.1",
  "description": "GlazeUI — Design System for Blazor + TailwindCSS",
  "private": true,
  "scripts": {
    "css:build": "npx @tailwindcss/cli -i Styles/input.css -o wwwroot/css/app.css --minify",
    "css:watch": "npx @tailwindcss/cli -i Styles/input.css -o wwwroot/css/app.css --watch",
    "dev": "concurrently \"dotnet watch\" \"npm run css:watch\"",
    "build": "npm run css:build && dotnet build"
  },
  "keywords": ["blazor", "tailwindcss", "design-system", "components"],
  "author": "GlazeUI Contributors",
  "license": "Apache-2.0",
  "devDependencies": {
    "tailwindcss": "^4.0.0",
    "@tailwindcss/cli": "^4.0.0"
  }
}
